{ kind != nil }
-- sql --
SELECT * FROM `otel_traces` WHERE ?
-- args --
[0] bool = true
-- seed --
CREATE TABLE otel_traces (
    SpanId String,
    SpanKind LowCardinality(String)
) ENGINE = MergeTree ORDER BY SpanId;
INSERT INTO otel_traces (SpanId, SpanKind) VALUES
    ('aaaa', 'Server'),
    ('bbbb', 'Unspecified'),
    ('cccc', 'Client');
