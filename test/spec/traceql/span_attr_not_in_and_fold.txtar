-- query.traceql --
{ span.http.method != "GET" && span.http.method != "POST" }
-- seed --
CREATE TABLE otel_traces (
    SpanId String,
    SpanAttributes Map(String, String) MATERIALIZED if(SpanId = 'aaaa', map('http.method', 'GET'), if(SpanId = 'bbbb', map('http.method', 'POST'), if(SpanId = 'cccc', map('http.method', 'DELETE'), map('http.method', 'PUT'))))
) ENGINE = MergeTree ORDER BY SpanId;
INSERT INTO otel_traces (SpanId) VALUES
    ('aaaa'),
    ('bbbb'),
    ('cccc'),
    ('dddd');
-- expected_rows --
[
  ["cccc"],
  ["dddd"]
]
-- args --
[0] string = "http.method"
[1] string = "GET"
[2] string = "POST"
-- chplan --
Filter predicate=not((SpanAttributes["http.method"] IN ("GET", "POST")))
  Scan(otel_traces)
-- sql --
SELECT * FROM `otel_traces` WHERE not((`SpanAttributes`[?] IN (?, ?)))
