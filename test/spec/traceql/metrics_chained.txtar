-- query.traceql --
{} | rate() | topk(5) > 1
-- sql --
SELECT * FROM (SELECT * FROM (SELECT toFloat64(count(?)) AS `Value` FROM (SELECT * FROM `otel_traces` WHERE ?)) ORDER BY `Value` DESC LIMIT 5) WHERE (`Value` > toFloat64(?))
-- args --
[0] int64 = 1
[1] bool = true
[2] float64 = 1
-- seed --
CREATE TABLE otel_traces (
    Duration UInt64
) ENGINE = Memory;
INSERT INTO otel_traces VALUES
    (10000000),
    (20000000),
    (30000000);
-- expected_rows --
[
  [3]
]
-- chplan --
MetricsSecondStage op=threshold threshold=(> 1) valueAlias=Value
  MetricsSecondStage op=topk k=5 valueAlias=Value
    MetricsAggregate op=rate valueAlias=Value
      Filter predicate=true
        Scan(otel_traces)
