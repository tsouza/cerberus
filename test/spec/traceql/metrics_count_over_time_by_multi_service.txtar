-- query.traceql --
{} | count_over_time() by (resource.service.name)
-- sql --
SELECT `ResourceAttributes`[?] AS `service.name`, toFloat64(count(?)) AS `Value` FROM (SELECT * FROM `otel_traces` WHERE ?) GROUP BY `ResourceAttributes`[?]
-- args --
[0] string = "service.name"
[1] int64 = 1
[2] bool = true
[3] string = "service.name"
-- seed --
CREATE TABLE otel_traces (
    ResourceAttributes Map(String, String)
) ENGINE = Memory;
INSERT INTO otel_traces VALUES
    (map('service.name', 'frontend')),
    (map('service.name', 'frontend')),
    (map('service.name', 'frontend')),
    (map('service.name', 'backend')),
    (map('service.name', 'backend'));
-- expected_rows --
[
  ["backend", 2],
  ["frontend", 3]
]
