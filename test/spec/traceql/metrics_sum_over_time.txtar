-- query.traceql --
{} | sum_over_time(duration)
-- sql --
SELECT sum(`Duration`) AS `Value` FROM (SELECT * FROM `otel_traces` WHERE ?)
-- args --
[0] bool = true
-- seed --
CREATE TABLE otel_traces (
    Duration UInt64
) ENGINE = Memory;
INSERT INTO otel_traces VALUES
    (50000000),
    (100000000),
    (200000000);
