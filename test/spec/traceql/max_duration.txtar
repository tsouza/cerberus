-- query.traceql --
{ resource.service.name = "frontend" } | max(duration) > 500ms
-- sql --
SELECT * FROM (SELECT max(`Duration`) AS `Value` FROM (SELECT * FROM (SELECT * FROM `otel_traces`) WHERE (`ResourceAttributes`[?] = ?))) WHERE (`Value` > ?)
-- args --
[0] string = "service.name"
[1] string = "frontend"
[2] int64 = 500000000
