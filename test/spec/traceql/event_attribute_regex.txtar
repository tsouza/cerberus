-- query.traceql --
{ event.exception.message =~ ".*timeout.*" }
-- sql --
SELECT * FROM `otel_traces` WHERE arrayExists(x -> match(x[?], ?), `Events`.`Attributes`)
-- args --
[0] string = "exception.message"
[1] string = ".*timeout.*"
-- seed --
CREATE TABLE otel_traces (
    _idx UInt64,
    `Events.Attributes` Array(Map(String, String)) MATERIALIZED if(_idx = 0, [map('exception.message', 'db timeout after 5s')], [map('exception.message', 'connection refused')])
) ENGINE = MergeTree ORDER BY _idx;
INSERT INTO otel_traces (_idx) VALUES (0), (1);
-- expected_rows --
[
  [0]
]
-- chplan --
Filter predicate=nestedArrayExists(Events.Attributes["exception.message"] =~ ".*timeout.*")
  Scan(otel_traces)
