-- query.traceql --
{ resource.service.name = "frontend" } | min(duration) > 10ms
-- sql --
SELECT * FROM (SELECT min(`Duration`) AS `Value` FROM (SELECT * FROM `otel_traces` WHERE (`ResourceAttributes`[?] = ?))) WHERE (`Value` > ?)
-- args --
[0] string = "service.name"
[1] string = "frontend"
[2] int64 = 10000000
