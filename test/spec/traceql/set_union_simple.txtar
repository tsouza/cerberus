-- query.traceql --
{ resource.service.name = "a" } || { resource.service.name = "b" }
-- sql --
(SELECT * FROM `otel_traces` WHERE (`ResourceAttributes`[?] = ?)) UNION DISTINCT (SELECT * FROM `otel_traces` WHERE (`ResourceAttributes`[?] = ?))
-- args --
[0] string = "service.name"
[1] string = "a"
[2] string = "service.name"
[3] string = "b"
