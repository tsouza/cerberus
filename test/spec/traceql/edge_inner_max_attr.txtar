-- query.traceql --
{ resource.service.name = "x" } | max(span.latency_ms) > 100
-- args --
[0] string = "latency_ms"
[1] string = "service.name"
[2] string = "x"
[3] int64 = 100
-- sql --
SELECT * FROM (SELECT max(`SpanAttributes`[?]) AS `Value` FROM (SELECT * FROM `otel_traces` WHERE (`ResourceAttributes`[?] = ?))) WHERE (`Value` > ?)
