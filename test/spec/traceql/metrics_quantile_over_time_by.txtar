-- query.traceql --
{} | quantile_over_time(duration, 0.95) by (resource.service.name)
-- seed --
CREATE TABLE otel_traces (
    Duration UInt64,
    ResourceAttributes Map(String, String)
) ENGINE = Memory;
INSERT INTO otel_traces VALUES
    (100000000, map('service.name', 'frontend')),
    (100000000, map('service.name', 'frontend')),
    (100000000, map('service.name', 'frontend')),
    (200000000, map('service.name', 'backend')),
    (200000000, map('service.name', 'backend'));
-- expected_rows --
[
  ["backend", 0.2],
  ["frontend", 0.1]
]
-- args --
[0] string = "service.name"
[1] float64 = 0.95
[2] float64 = 1e+09
[3] bool = true
[4] string = "service.name"
-- chplan --
MetricsAggregate op=quantile_over_time attr=(Duration / 1e+09) groupBy=[ResourceAttributes["service.name"] AS service.name|resource.service.name] quantiles=[0.95] duration=true valueAlias=Value
  Filter predicate=true
    Scan(otel_traces)
-- sql --
SELECT `ResourceAttributes`[?] AS `service.name`, quantile(toFloat64(?))((`Duration` / toFloat64(?))) AS `Value` FROM (SELECT * FROM `otel_traces` WHERE ?) GROUP BY `ResourceAttributes`[?]
