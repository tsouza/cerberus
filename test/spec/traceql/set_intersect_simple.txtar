-- query.traceql --
{ resource.service.name = "a" } && { duration > 1s }
-- sql --
SELECT L.* FROM (SELECT * FROM `otel_traces` WHERE (`ResourceAttributes`[?] = ?)) AS `L` INNER JOIN (SELECT * FROM `otel_traces` WHERE (`Duration` > ?)) AS `R` ON `L`.`TraceId` = `R`.`TraceId` AND `L`.`SpanId` = `R`.`SpanId`
-- args --
[0] string = "service.name"
[1] string = "a"
[2] int64 = 1000000000
-- chplan --
SetOperation op=&&
  Filter predicate=(ResourceAttributes["service.name"] = "a")
    Scan(otel_traces)
  Filter predicate=(Duration > 1000000000)
    Scan(otel_traces)
