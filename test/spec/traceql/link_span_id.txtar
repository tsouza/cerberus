-- query.traceql --
{ link.span_id = "abc" }
-- sql --
SELECT * FROM `otel_traces` WHERE arrayExists(x -> x[?] = ?, `Links`.`Attributes`)
-- args --
[0] string = "span_id"
[1] string = "abc"
-- seed --
CREATE TABLE otel_traces (
    _idx UInt64,
    `Links.Attributes` Array(Map(String, String)) MATERIALIZED if(_idx = 0, [map('span_id', 'abc')], [map('span_id', 'def')])
) ENGINE = MergeTree ORDER BY _idx;
INSERT INTO otel_traces (_idx) VALUES (0), (1);
-- expected_rows --
[
  [0]
]
-- chplan --
Filter predicate=nestedArrayExists(Links.Attributes["span_id"] = "abc")
  Scan(otel_traces)
