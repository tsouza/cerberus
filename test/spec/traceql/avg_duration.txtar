-- query.traceql --
{ resource.service.name = "frontend" } | avg(duration) > 50ms
-- sql --
SELECT * FROM (SELECT avg(`Duration`) AS `Value` FROM (SELECT * FROM `otel_traces` WHERE (`ResourceAttributes`[?] = ?))) WHERE (`Value` > ?)
-- args --
[0] string = "service.name"
[1] string = "frontend"
[2] int64 = 50000000
