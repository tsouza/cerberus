-- query.traceql --
{ resource.service.name = "frontend" } | count() = 0
-- sql --
SELECT * FROM (SELECT count(?) AS `Value` FROM (SELECT * FROM `otel_traces` WHERE (`ResourceAttributes`[?] = ?))) WHERE (`Value` = ?)
-- args --
[0] int64 = 1
[1] string = "service.name"
[2] string = "frontend"
[3] int64 = 0
