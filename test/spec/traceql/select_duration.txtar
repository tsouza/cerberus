-- query.traceql --
{ resource.service.name = "frontend" } | select(duration)
-- seed --
CREATE TABLE otel_traces (
    TraceId String,
    SpanId String,
    Timestamp DateTime64(9),
    Duration UInt64,
    ResourceAttributes Map(String, String)
) ENGINE = Memory;
INSERT INTO otel_traces VALUES
    ('a0000000000000000000000000000001', '0000000000000001', toDateTime64('2026-01-01 00:00:00', 9), 150000000, map('service.name', 'frontend')),
    ('a0000000000000000000000000000002', '0000000000000002', toDateTime64('2026-01-01 00:00:01', 9), 90000000, map('service.name', 'backend'));
-- expected_rows --
[
  ["a0000000000000000000000000000001", "0000000000000001", "2026-01-01T00:00:00Z", 150000000]
]
-- args --
[0] string = "service.name"
[1] string = "frontend"
-- chplan --
Project [TraceId, SpanId, Timestamp, Duration AS duration]
  Filter predicate=(ResourceAttributes["service.name"] = "frontend")
    Scan(otel_traces)
-- sql --
SELECT `TraceId`, `SpanId`, `Timestamp`, `Duration` AS `duration` FROM (SELECT * FROM `otel_traces` WHERE (`ResourceAttributes`[?] = ?))
