-- query.traceql --
{} | coalesce()
-- sql --
SELECT `TraceId` AS `TraceId`, `SpanId` AS `SpanId`, min(`Timestamp`) AS `Timestamp` FROM (SELECT * FROM `otel_traces` WHERE ?) GROUP BY `TraceId`, `SpanId`
-- args --
[0] bool = true
-- seed --
CREATE TABLE otel_traces (
    TraceId String,
    SpanId String,
    Timestamp DateTime64(9)
) ENGINE = Memory;
