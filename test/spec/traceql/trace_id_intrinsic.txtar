-- query.traceql --
{ trace:id = "abcdef0123456789" }
-- sql --
SELECT * FROM `otel_traces` WHERE (`TraceId` = ?)
-- args --
[0] string = "abcdef0123456789"
-- seed --
CREATE TABLE otel_traces (
    TraceId String
) ENGINE = Memory;
INSERT INTO otel_traces VALUES
    ('0123456789abcdef'),
    ('abcdef0123456789'),
    ('fedcba9876543210');
-- expected_rows --
[
  ["abcdef0123456789"]
]
-- chplan --
Filter predicate=(TraceId = "abcdef0123456789")
  Scan(otel_traces)
