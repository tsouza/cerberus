-- query.traceql --
{} | avg_over_time(span.latency_ms)
-- seed --
CREATE TABLE otel_traces (
    SpanAttributes Map(String, String)
) ENGINE = Memory;
INSERT INTO otel_traces VALUES
    (map('latency_ms', '10')),
    (map('latency_ms', '20')),
    (map('latency_ms', '30'));
-- expected_rows --
[
  [20]
]
-- args --
[0] string = "latency_ms"
[1] bool = true
-- chplan --
MetricsAggregate op=avg_over_time attr=toFloat64OrZero(SpanAttributes["latency_ms"]) valueAlias=Value
  Filter predicate=true
    Scan(otel_traces)
-- sql --
SELECT avg(toFloat64OrZero(`SpanAttributes`[?])) AS `Value` FROM (SELECT * FROM `otel_traces` WHERE ?)
