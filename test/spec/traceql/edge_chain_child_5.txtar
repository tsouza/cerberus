-- query.traceql --
{ resource.service.name = "a" } > { resource.service.name = "b" } > { resource.service.name = "c" } > { resource.service.name = "d" } > { resource.service.name = "e" }
-- args --
[0] string = "service.name"
[1] string = "a"
[2] string = "service.name"
[3] string = "b"
[4] string = "service.name"
[5] string = "c"
