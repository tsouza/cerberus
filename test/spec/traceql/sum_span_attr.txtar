-- query.traceql --
{ span.http.status_code >= 400 } | sum(span.http.status_code) > 0
-- sql --
SELECT * FROM (SELECT sum(`SpanAttributes`[?]) AS `Value` FROM (SELECT * FROM (SELECT * FROM `otel_traces`) WHERE (`SpanAttributes`[?] >= ?))) WHERE (`Value` > ?)
-- args --
[0] string = "http.status_code"
[1] string = "http.status_code"
[2] int64 = 400
[3] int64 = 0
