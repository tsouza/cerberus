-- query.traceql --
{ .a * 2 > 10 }
-- sql --
SELECT * FROM `otel_traces` WHERE ((toFloat64OrNull(`SpanAttributes`[?]) * ?) > ?)
-- args --
[0] string = "a"
[1] int64 = 2
[2] int64 = 10
-- seed --
CREATE TABLE otel_traces (
    _idx UInt64,
    SpanAttributes Map(String, String) MATERIALIZED map('a', if(_idx = 0, '7', '3'))
) ENGINE = MergeTree ORDER BY _idx;
INSERT INTO otel_traces (_idx) VALUES (0), (1);
-- expected_rows --
[
  [0]
]
-- chplan --
Filter predicate=((toFloat64OrNull(SpanAttributes["a"]) * 2) > 10)
  Scan(otel_traces)
