The exact query shape Grafana Traces Drilldown's "Structure" tab sends
(rate metric; see traces-drilldown
src/components/Explore/TracesByService/Tabs/Structure/StructureScene.tsx
buildQuery): a union-structural arm OR'd with a plain filter arm, piped
into a select() that includes the three nested-set intrinsics.

Pins three behaviours at once:

  1. nested-set intrinsics in select() over a non-trivial input
     (SetOperation over StructuralJoin) — NestedSetAnnotate wraps the
     whole spanset expression;
  2. `||` arm alignment — the structural arm exposes the narrow span
     envelope while the plain arm is `SELECT *`; the lowering projects
     the plain arm down to the same ordered column list (CH error 258
     UNION_ALL_RESULT_STRUCTURES_MISMATCH otherwise);
  3. select() of status / resource attrs / name over a structural
     result — needs StatusCode etc. in the structural arm's exposed
     columns (structuralExtraProjectionColumns).

Seed: one trace, root r1 (Server/frontend) → c1 (Internal/auth),
c2 (Server/checkout, Error) → g1 (Client/db). `{nestedSetParent<0}` =
r1; `&>> {kind=server}` matches descendant c2 and (union form) r1
itself; the `|| {nestedSetParent<0}` arm re-adds r1 — result {r1, c2}.
Numbering: r1 (1,8,-1), c1 (2,3,1), c2 (4,7,1), g1 (5,6,4). The
`status` column carries the stored TitleCase enum at the engine layer;
the API wrap lowercases it for the wire.

-- query.traceql --
({ nestedSetParent < 0 } &>> { kind = server }) || ({ nestedSetParent < 0 }) | select(status, resource.service.name, name, nestedSetParent, nestedSetLeft, nestedSetRight)
-- sql --
SELECT `TraceId`, `SpanId`, `Timestamp`, `StatusCode` AS `status`, `ResourceAttributes`[?] AS `service.name`, `SpanName` AS `name`, `__cerberus_ns_parent` AS `nestedSetParent`, `__cerberus_ns_left` AS `nestedSetLeft`, `__cerberus_ns_right` AS `nestedSetRight` FROM (SELECT m.*, ifNull(`ns`.`_ns_left`, 0) AS `__cerberus_ns_left`, ifNull(`ns`.`_ns_right`, 0) AS `__cerberus_ns_right`, ifNull(`ns`.`_ns_parent`, 0) AS `__cerberus_ns_parent` FROM (((SELECT R.`TraceId` AS `TraceId`, R.`SpanId` AS `SpanId`, R.`ParentSpanId` AS `ParentSpanId`, R.`SpanName` AS `SpanName`, R.`Duration` AS `Duration`, R.`Timestamp` AS `Timestamp`, R.`ResourceAttributes` AS `ResourceAttributes`, R.`SpanAttributes` AS `SpanAttributes`, R.`StatusCode` AS `StatusCode`, R.`StatusMessage` AS `StatusMessage`, R.`SpanKind` AS `SpanKind`, R.`ScopeName` AS `ScopeName`, R.`ScopeVersion` AS `ScopeVersion` FROM (WITH RECURSIVE _struct_closure AS (SELECT DISTINCT `TraceId`, `SpanId`, `ParentSpanId`, 0 AS _depth FROM (SELECT * FROM `otel_traces` WHERE (`ParentSpanId` = ?)) AS _seed UNION ALL SELECT DISTINCT t.`TraceId`, t.`SpanId`, t.`ParentSpanId`, c._depth + 1 FROM `otel_traces` AS t INNER JOIN _struct_closure AS c ON t.`TraceId` = c.`TraceId` AND t.`ParentSpanId` = c.`SpanId`) SELECT DISTINCT `TraceId`, `SpanId` FROM _struct_closure WHERE _depth > 0) AS L INNER JOIN (SELECT * FROM `otel_traces` WHERE (`SpanKind` = ?)) AS R ON L.`TraceId` = R.`TraceId` AND L.`SpanId` = R.`SpanId`) UNION DISTINCT (SELECT L.`TraceId` AS `TraceId`, L.`SpanId` AS `SpanId`, L.`ParentSpanId` AS `ParentSpanId`, L.`SpanName` AS `SpanName`, L.`Duration` AS `Duration`, L.`Timestamp` AS `Timestamp`, L.`ResourceAttributes` AS `ResourceAttributes`, L.`SpanAttributes` AS `SpanAttributes`, L.`StatusCode` AS `StatusCode`, L.`StatusMessage` AS `StatusMessage`, L.`SpanKind` AS `SpanKind`, L.`ScopeName` AS `ScopeName`, L.`ScopeVersion` AS `ScopeVersion` FROM (SELECT * FROM `otel_traces` WHERE (`ParentSpanId` = ?)) AS L INNER JOIN (WITH RECURSIVE _struct_closure_inv AS (SELECT DISTINCT `TraceId`, `SpanId`, `ParentSpanId`, 0 AS _depth FROM (SELECT * FROM `otel_traces` WHERE (`SpanKind` = ?)) AS _seed UNION ALL SELECT DISTINCT t.`TraceId`, t.`SpanId`, t.`ParentSpanId`, c._depth + 1 FROM `otel_traces` AS t INNER JOIN _struct_closure_inv AS c ON t.`TraceId` = c.`TraceId` AND t.`SpanId` = c.`ParentSpanId`) SELECT DISTINCT `TraceId`, `SpanId` FROM _struct_closure_inv WHERE _depth > 0) AS R ON L.`TraceId` = R.`TraceId` AND L.`SpanId` = R.`SpanId`)) UNION DISTINCT (SELECT `TraceId`, `SpanId`, `ParentSpanId`, `SpanName`, `Duration`, `Timestamp`, `ResourceAttributes`, `SpanAttributes`, `StatusCode`, `StatusMessage`, `SpanKind`, `ScopeName`, `ScopeVersion` FROM (SELECT * FROM `otel_traces` WHERE (`ParentSpanId` = ?)))) AS m LEFT JOIN (WITH RECURSIVE _cerberus_ns_paths AS (SELECT `TraceId`, `SpanId`, `ParentSpanId`, concat(leftPad(toString(toUnixTimestamp64Nano(`Timestamp`)), 20, '0'), leftPad(toString(sipHash64(`SpanId`)), 20, '0')) AS `_path` FROM `otel_traces` WHERE `ParentSpanId` = '' AND `TraceId` IN (((SELECT `TraceId` FROM (SELECT * FROM `otel_traces` WHERE (`ParentSpanId` = ?))) UNION ALL (SELECT `TraceId` FROM (SELECT * FROM `otel_traces` WHERE (`SpanKind` = ?)))) UNION ALL (SELECT `TraceId` FROM (SELECT * FROM `otel_traces` WHERE (`ParentSpanId` = ?)))) UNION ALL SELECT t.`TraceId`, t.`SpanId`, t.`ParentSpanId`, concat(c.`_path`, concat(leftPad(toString(toUnixTimestamp64Nano(`t`.`Timestamp`)), 20, '0'), leftPad(toString(sipHash64(`t`.`SpanId`)), 20, '0'))) FROM `otel_traces` AS t INNER JOIN `_cerberus_ns_paths` AS c ON t.`TraceId` = c.`TraceId` AND t.`ParentSpanId` = c.`SpanId`) SELECT `TraceId`, `SpanId`, toInt64(maxIf(`_erank`, `_etype` = 0)) AS `_ns_left`, toInt64(maxIf(`_erank`, `_etype` = 2)) AS `_ns_right`, if(countIf(`_etype` = 1) = 0, toInt64(-1), toInt64(maxIf(`_keyrank`, `_etype` = 1))) AS `_ns_parent` FROM (SELECT `TraceId`, `SpanId`, `_etype`, `_erank`, first_value(`_erank`) OVER (PARTITION BY `TraceId`, `_ekey` ORDER BY `_etype` ASC ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS `_keyrank` FROM (SELECT `TraceId`, `SpanId`, `_ekey`, `_etype`, sum(`_etype` != 1) OVER (PARTITION BY `TraceId` ORDER BY `_ekey` ASC, `_etype` ASC ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS `_erank` FROM (SELECT `TraceId`, `SpanId`, `_ev`.1 AS `_ekey`, `_ev`.2 AS `_etype` FROM `_cerberus_ns_paths` ARRAY JOIN arrayFilter(e -> NOT (e.2 = 1 AND e.1 = ''), [(`_path`, 0), (concat(`_path`, '~'), 2), (substring(`_path`, 1, length(`_path`) - 40), 1)]) AS `_ev`))) GROUP BY `TraceId`, `SpanId`) AS ns ON m.`TraceId` = ns.`TraceId` AND m.`SpanId` = ns.`SpanId`)
-- args --
[0] string = "service.name"
[1] string = ""
[2] string = "Server"
[3] string = ""
[4] string = "Server"
[5] string = ""
[6] string = ""
[7] string = "Server"
[8] string = ""
-- seed --
CREATE TABLE otel_traces (
    TraceId String,
    SpanId String,
    ParentSpanId String,
    SpanName String,
    SpanKind String,
    Duration Int64,
    Timestamp DateTime64(9),
    StatusCode String,
    StatusMessage String,
    ScopeName String,
    ScopeVersion String,
    SpanAttributes Map(String, String),
    ResourceAttributes Map(String, String)
) ENGINE = Memory;
INSERT INTO otel_traces VALUES
    ('a0000000000000000000000000000001', '1000000000000001', '', 'GET /home', 'Server', 1000, toDateTime64('2026-01-01 00:00:00.000000001', 9), 'Unset', '', '', '', map(), map('service.name', 'frontend')),
    ('a0000000000000000000000000000001', '1000000000000002', '1000000000000001', 'auth', 'Internal', 500, toDateTime64('2026-01-01 00:00:00.000000002', 9), 'Unset', '', '', '', map(), map('service.name', 'auth')),
    ('a0000000000000000000000000000001', '1000000000000003', '1000000000000001', 'checkout', 'Server', 700, toDateTime64('2026-01-01 00:00:00.000000003', 9), 'Error', '', '', '', map(), map('service.name', 'checkout')),
    ('a0000000000000000000000000000001', '1000000000000004', '1000000000000003', 'db', 'Client', 300, toDateTime64('2026-01-01 00:00:00.000000004', 9), 'Unset', '', '', '', map(), map('service.name', 'db'));
-- expected_rows --
[
  ["a0000000000000000000000000000001", "1000000000000001", "2026-01-01T00:00:00.000000001Z", "Unset", "frontend", "GET /home", -1, 1, 8],
  ["a0000000000000000000000000000001", "1000000000000003", "2026-01-01T00:00:00.000000003Z", "Error", "checkout", "checkout", 1, 4, 7]
]
-- chplan --
Project [TraceId, SpanId, Timestamp, StatusCode AS status, ResourceAttributes["service.name"] AS service.name, SpanName AS name, __cerberus_ns_parent AS nestedSetParent, __cerberus_ns_left AS nestedSetLeft, __cerberus_ns_right AS nestedSetRight]
  NestedSetAnnotate table=otel_traces
    SetOperation op=||
      StructuralJoin op=&>>
        Filter predicate=(ParentSpanId = "")
          Scan(otel_traces)
        Filter predicate=(SpanKind = "Server")
          Scan(otel_traces)
      Project [TraceId, SpanId, ParentSpanId, SpanName, Duration, Timestamp, ResourceAttributes, SpanAttributes, StatusCode, StatusMessage, SpanKind, ScopeName, ScopeVersion]
        Filter predicate=(ParentSpanId = "")
          Scan(otel_traces)
