-- query.traceql --
{} | quantile_over_time(duration, 0.95)
-- sql --
SELECT quantile(?)((`Duration` / ?)) AS `Value` FROM (SELECT * FROM `otel_traces` WHERE ?)
-- args --
[0] float64 = 0.95
[1] float64 = 1e+09
[2] bool = true
-- seed --
CREATE TABLE otel_traces (
    Duration UInt64
) ENGINE = Memory;
INSERT INTO otel_traces VALUES
    (100000000),
    (100000000),
    (100000000),
    (100000000),
    (100000000);
-- expected_rows --
[
  [0.1]
]
-- chplan --
