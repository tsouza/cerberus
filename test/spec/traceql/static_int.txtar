-- query.traceql --
{ .attempt = 1 }
-- sql --
SELECT * FROM `otel_traces` WHERE (toFloat64OrNull(`SpanAttributes`[?]) = ?)
-- args --
[0] string = "attempt"
[1] int64 = 1
-- seed --
CREATE TABLE otel_traces (
    _idx UInt64,
    SpanAttributes Map(String, String) MATERIALIZED map('attempt', if(_idx = 0, '1', '2'))
) ENGINE = MergeTree ORDER BY _idx;
INSERT INTO otel_traces (_idx) VALUES (0), (1);
-- expected_rows --
[
  [0]
]
-- chplan --
Filter predicate=(toFloat64OrNull(SpanAttributes["attempt"]) = 1)
  Scan(otel_traces)
