-- query.traceql --
{} | histogram_over_time(duration)
-- sql --
SELECT log2(`Duration`) / 1000000000 AS `__bucket`, count(?) AS `Value` FROM (SELECT * FROM `otel_traces` WHERE ?) WHERE `Duration` >= 2 GROUP BY `__bucket`
-- args --
[0] int64 = 1
[1] bool = true
-- seed --
CREATE TABLE otel_traces (
    Duration UInt64
) ENGINE = Memory;
INSERT INTO otel_traces VALUES
    (1024),
    (1024),
    (1024);
-- expected_rows --
[
  [1.0e-08, 3]
]