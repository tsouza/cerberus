    (toDateTime64('2025-12-31 23:58:00', 9), 'a', map('service_name', 'api')),
    (toDateTime64('2025-12-31 23:59:00', 9), 'b', map('service_name', 'api')),
    (toDateTime64('2026-01-01 00:00:00', 9), 'c', map('service_name', 'api'));
