-- query.logql --
{job="api"} | level="ERROR"
-- sql --
SELECT * FROM `otel_logs` WHERE (`ResourceAttributes`[?] = ?) AND (`ResourceAttributes`[?] = ?)
-- args --
[0] string = "job"
[1] string = "api"
[2] string = "level"
[3] string = "ERROR"
-- seed --
CREATE TABLE otel_logs (
    Body String,
    ResourceAttributes Map(String, String) MATERIALIZED map(
        'job', 'api',
        'level', if(Body = 'info log', 'INFO', 'ERROR')
    )
) ENGINE = Memory;
INSERT INTO otel_logs (Body) VALUES ('error log one'), ('error log two'), ('info log');
-- expected_rows --
[
  ["error log one"],
  ["error log two"]
]
-- chplan --
Filter predicate=((ResourceAttributes["job"] = "api") AND (ResourceAttributes["level"] = "ERROR"))
  Scan(otel_logs)
