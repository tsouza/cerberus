-- query.logql --
{ job = "api" }
-- sql --
SELECT * FROM `otel_logs` WHERE (`ResourceAttributes`[?] = ?)
-- args --
[0] string = "job"
[1] string = "api"
-- seed --
CREATE TABLE otel_logs (
    Body String,
    ResourceAttributes Map(String, String) MATERIALIZED map('job', 'api')
) ENGINE = Memory;
