-- query.logql --
{job="api"} |= "a" != "b" |~ "c"
-- sql --
SELECT * FROM (SELECT * FROM `otel_logs`) WHERE ((`ResourceAttributes`[?] = ?) AND (((position(`Body`, ?) > 0) AND (position(`Body`, ?) = 0)) AND match(`Body`, ?)))
-- args --
[0] string = "job"
[1] string = "api"
[2] string = "a"
[3] string = "b"
[4] string = "c"
