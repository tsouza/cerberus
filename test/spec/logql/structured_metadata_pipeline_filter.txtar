{service_name="clickhouse"} | query_kind="Select"
-- seed --
CREATE TABLE otel_logs (
    ServiceName LowCardinality(String) DEFAULT 'clickhouse',
    Body String,
    ResourceAttributes Map(String, String) MATERIALIZED map('service_name', 'clickhouse'),
    LogAttributes Map(String, String) MATERIALIZED map(
        'query_kind', if(Body = 'q2', 'Insert', 'Select'),
        'query_duration_ms', Body
    )
) ENGINE = Memory;
INSERT INTO otel_logs (Body) VALUES ('q1'), ('q2'), ('q3');
-- expected_rows --
[
  ["clickhouse", "q1"],
  ["clickhouse", "q3"]
]
-- chplan --
Filter predicate=((coalesce(nullIf(ServiceName, ""), if(mapContains(ResourceAttributes, "service_name"), ResourceAttributes["service_name"], if(mapContains(ResourceAttributes, "service.name"), ResourceAttributes["service.name"], ResourceAttributes["service/name"]))) = "clickhouse") AND (if(((mapContains(LogAttributes, "query_kind") OR mapContains(LogAttributes, "query.kind")) OR mapContains(LogAttributes, "query/kind")), if(mapContains(LogAttributes, "query_kind"), LogAttributes["query_kind"], if(mapContains(LogAttributes, "query.kind"), LogAttributes["query.kind"], LogAttributes["query/kind"])), if(mapContains(ResourceAttributes, "query_kind"), ResourceAttributes["query_kind"], if(mapContains(ResourceAttributes, "query.kind"), ResourceAttributes["query.kind"], ResourceAttributes["query/kind"]))) = "Select"))
  Scan(otel_logs)
