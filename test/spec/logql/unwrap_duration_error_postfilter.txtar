-- seed --
CREATE TABLE otel_logs (
    Timestamp DateTime64(9),
    Body String,
    SeverityText LowCardinality(String) DEFAULT '',
    ResourceAttributes Map(String, String)
) ENGINE = Memory;
INSERT INTO otel_logs (Timestamp, Body, ResourceAttributes) VALUES
    (toDateTime64('2025-12-31 23:58:00', 9), 'latency=500000Âµs msg=ok', map('job', 'api')),
    (toDateTime64('2025-12-31 23:58:30', 9), 'latency=1500000us msg=ok', map('job', 'api')),
    (toDateTime64('2025-12-31 23:59:00', 9), 'latency=1000000ÎĽs msg=ok', map('job', 'api')),
    (toDateTime64('2025-12-31 23:59:30', 9), 'latency=oops msg=ok', map('job', 'api')),
    (toDateTime64('2026-01-01 00:00:00', 9), 'msg=ok', map('job', 'api'));
