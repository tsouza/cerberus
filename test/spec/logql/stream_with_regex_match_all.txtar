-- query.logql --
{service_name=~".*"}
-- sql --
SELECT * FROM `otel_logs` WHERE match(coalesce(nullIf(`ServiceName`, ?), if(mapContains(`ResourceAttributes`, ?), `ResourceAttributes`[?], if(mapContains(`ResourceAttributes`, ?), `ResourceAttributes`[?], `ResourceAttributes`[?]))), ?)
-- args --
[0] string = ""
[1] string = "service_name"
[2] string = "service_name"
[3] string = "service.name"
[4] string = "service.name"
[5] string = "service/name"
[6] string = ".*"
-- seed --
CREATE TABLE otel_logs (
    Body String,
    ResourceAttributes Map(String, String) MATERIALIZED if(
        Body = 'r1', map('service_name', 'api'),
        if(Body = 'r2', map('service.name', 'web'),
           if(Body = 'r3', map('service_name', ''),
              map()))),
    ServiceName String MATERIALIZED ''
) ENGINE = Memory;
INSERT INTO otel_logs (Body) VALUES ('r1'), ('r2'), ('r3'), ('r4');
-- expected_rows --
[
  ["r1"],
  ["r2"],
  ["r3"],
  ["r4"]
]
-- chplan --
Filter predicate=(coalesce(nullIf(ServiceName, ""), if(mapContains(ResourceAttributes, "service_name"), ResourceAttributes["service_name"], if(mapContains(ResourceAttributes, "service.name"), ResourceAttributes["service.name"], ResourceAttributes["service/name"]))) =~ ".*")
  Scan(otel_logs)
