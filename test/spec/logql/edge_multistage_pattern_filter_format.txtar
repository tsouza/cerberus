-- query.logql --
{job="api"} | pattern "<_> <level> <msg>" | level="error" | line_format "ERR: {{.msg}}"
-- args --
[0] string = "job"
[1] string = "api"
[2] string = "level"
[3] string = "error"
-- sql --
SELECT * FROM `otel_logs` WHERE (`ResourceAttributes`[?] = ?) AND (`ResourceAttributes`[?] = ?)
-- chplan --
Filter predicate=((ResourceAttributes["job"] = "api") AND (ResourceAttributes["level"] = "error"))
  Scan(otel_logs)
