-- query.logql --
{job="api"} | pattern "<_> <level> <msg>" | level="error" | line_format "ERR: {{.msg}}"
-- args --
[0] string = "job"
[1] string = "api"
[2] string = "level"
[3] string = "level"
[4] string = "level"
[5] string = "error"
-- sql --
SELECT * FROM `otel_logs` WHERE (`ResourceAttributes`[?] = ?) AND (if(mapContains(`LogAttributes`, ?), `LogAttributes`[?], `ResourceAttributes`[?]) = ?)
-- seed --
CREATE TABLE otel_logs (
    LogAttributes Map(String, String) MATERIALIZED map(),
    Body String,
    ResourceAttributes Map(String, String) MATERIALIZED map(
        'job', 'api',
        'level', if(Body LIKE 'm1%', 'error', if(Body LIKE 'm2%', 'error', if(Body LIKE 'm3%', 'warn', 'info')))
    )
) ENGINE = Memory;
INSERT INTO otel_logs (Body) VALUES
    ('m1 ts error db timeout'),
    ('m2 ts error upstream gone'),
    ('m3 ts warn slow query'),
    ('m4 ts info background sync');
-- expected_rows --
[
  ["m1 ts error db timeout"],
  ["m2 ts error upstream gone"]
]
-- chplan --
Filter predicate=((ResourceAttributes["job"] = "api") AND (if(mapContains(LogAttributes, "level"), LogAttributes["level"], ResourceAttributes["level"]) = "error"))
  Scan(otel_logs)
