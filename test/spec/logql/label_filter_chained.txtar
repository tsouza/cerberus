-- query.logql --
{job="api"} |= "error" | env="prod" | severity="high"
-- sql --
SELECT * FROM `otel_logs` WHERE (`ResourceAttributes`[?] = ?) AND (position(`Body`, ?) > 0) AND (`ResourceAttributes`[?] = ?) AND (`ResourceAttributes`[?] = ?)
-- args --
[0] string = "job"
[1] string = "api"
[2] string = "error"
[3] string = "env"
[4] string = "prod"
[5] string = "severity"
[6] string = "high"
