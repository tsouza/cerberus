-- query.logql --
{job="api"} |= "error" | line_format "[{{.job}}] {{__line__}}"
-- sql --
SELECT * FROM `otel_logs` WHERE (`ResourceAttributes`[?] = ?) AND (position(`Body`, ?) > 0)
-- args --
[0] string = "job"
[1] string = "api"
[2] string = "error"
-- seed --
CREATE TABLE otel_logs (
    Body String,
    ResourceAttributes Map(String, String) MATERIALIZED map('job', 'api')
) ENGINE = Memory;
INSERT INTO otel_logs (Body) VALUES
    ('error happened'),
    ('all good'),
    ('error retry');
-- expected_rows --
[
  ["error happened"],
  ["error retry"]
]
