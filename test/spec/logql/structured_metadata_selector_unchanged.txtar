{service_name="clickhouse", tier="gold"}
-- seed --
CREATE TABLE otel_logs (
    ServiceName LowCardinality(String) DEFAULT 'clickhouse',
    Body String,
    ResourceAttributes Map(String, String) MATERIALIZED map('service_name', 'clickhouse'),
    LogAttributes Map(String, String) MATERIALIZED map('tier', 'gold')
) ENGINE = Memory;
INSERT INTO otel_logs (Body) VALUES ('a'), ('b');
-- expected_rows --
[]
-- chplan --
Filter predicate=((coalesce(nullIf(ServiceName, ""), if(mapContains(ResourceAttributes, "service_name"), ResourceAttributes["service_name"], ResourceAttributes["service.name"])) = "clickhouse") AND (ResourceAttributes["tier"] = "gold"))
  Scan(otel_logs)
-- sql --
SELECT * FROM `otel_logs` WHERE (coalesce(nullIf(`ServiceName`, ?), if(mapContains(`ResourceAttributes`, ?), `ResourceAttributes`[?], `ResourceAttributes`[?])) = ?) AND (`ResourceAttributes`[?] = ?)
-- args --
[0] string = ""
[1] string = "service_name"
[2] string = "service_name"
[3] string = "service.name"
[4] string = "clickhouse"
[5] string = "tier"
[6] string = "gold"
