-- query.logql --
{job="api"} | label_format svc=job
-- sql --
SELECT * FROM `otel_logs` WHERE (`ResourceAttributes`[?] = ?)
-- args --
[0] string = "job"
[1] string = "api"
-- seed --
CREATE TABLE otel_logs (
    Body String,
    ResourceAttributes Map(String, String) MATERIALIZED map('job', 'api')
) ENGINE = Memory;
INSERT INTO otel_logs (Body) VALUES ('lf1');
