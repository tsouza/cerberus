-- query.logql --
{job="api"} | logfmt | status > 400
-- args --
[0] string = "job"
[1] string = "api"
[2] string = "_extracted"
[3] string = "="
[4] string = " "
[5] string = "\""
[6] string = "status"
[7] float64 = 400
-- seed --
CREATE TABLE otel_logs (
    Body String,
    ResourceAttributes Map(String, String) MATERIALIZED map('job', 'api')
) ENGINE = Memory;
INSERT INTO otel_logs (Body) VALUES
    ('ts=2026-01-01 status=200 msg="ok"'),
    ('ts=2026-01-01 status=500 msg="server_error"'),
    ('ts=2026-01-01 status=503 msg="unavailable"');
-- expected_rows --
[
  ["ts=2026-01-01 status=500 msg=\"server_error\""],
  ["ts=2026-01-01 status=503 msg=\"unavailable\""]
]
-- chplan --
Filter predicate=((ResourceAttributes["job"] = "api") AND (toFloat64OrZero(mapConcat(ResourceAttributes, mapApply((k, v) -> tuple(if(mapContains(ResourceAttributes, k), concat(k, "_extracted"), k), v), extractKeyValuePairs(Body, "=", " ", "\"")))["status"]) > 400))
  Scan(otel_logs)
-- sql --
SELECT * FROM `otel_logs` WHERE (`ResourceAttributes`[?] = ?) AND (toFloat64OrZero(mapConcat(`ResourceAttributes`, mapApply((k, v) -> tuple(if(mapContains(`ResourceAttributes`, k), concat(k, ?), k), v), extractKeyValuePairs(`Body`, ?, ?, ?)))[?]) > ?)
