-- chplan --
Filter predicate=((coalesce(nullIf(ServiceName, ""), if(mapContains(ResourceAttributes, "service_name"), ResourceAttributes["service_name"], ResourceAttributes["service.name"])) = "api") AND ((Timestamp >= toDateTime64("2026-05-14 12:03:20.000000000", 9)) AND (Timestamp <= toDateTime64("2026-05-14 12:05:00.000000000", 9))))
