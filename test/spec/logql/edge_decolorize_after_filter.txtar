-- query.logql --
{job="api"} |= "error" | decolorize
-- args --
[0] string = "job"
[1] string = "api"
[2] string = "error"
-- sql --
SELECT * FROM `otel_logs` WHERE (`ResourceAttributes`[?] = ?) AND (position(`Body`, ?) > 0)
-- chplan --
Filter predicate=((ResourceAttributes["job"] = "api") AND lineContent(Body, "error", substr))
  Scan(otel_logs)
