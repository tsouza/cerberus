-- query.logql --
{job="api"} |= "error" or "fatal" or "panic"
-- args --
[0] string = "job"
[1] string = "api"
[2] string = "error"
[3] string = "fatal"
[4] string = "panic"
-- sql --
SELECT * FROM `otel_logs` WHERE (`ResourceAttributes`[?] = ?) AND (((position(`Body`, ?) > 0) OR (position(`Body`, ?) > 0)) OR (position(`Body`, ?) > 0))
