-- seed --
CREATE TABLE otel_logs (
    Timestamp DateTime64(9),
    Body String,
    SeverityText LowCardinality(String) DEFAULT '',
    ResourceAttributes Map(String, String)
) ENGINE = Memory;
INSERT INTO otel_logs (Timestamp, Body, ResourceAttributes) VALUES
    (toDateTime64('2025-12-31 23:58:00', 9), 'latency=1ns msg=u_ns', map('job', 'api')),
    (toDateTime64('2025-12-31 23:58:01', 9), 'latency=1us msg=u_us', map('job', 'api')),
    (toDateTime64('2025-12-31 23:58:02', 9), 'latency=1Âµs msg=u_micro_sign', map('job', 'api')),
    (toDateTime64('2025-12-31 23:58:03', 9), 'latency=1ÎĽs msg=u_greek_mu', map('job', 'api')),
    (toDateTime64('2025-12-31 23:58:04', 9), 'latency=1ms msg=u_ms', map('job', 'api')),
    (toDateTime64('2025-12-31 23:58:05', 9), 'latency=1s msg=u_s', map('job', 'api')),
    (toDateTime64('2025-12-31 23:58:06', 9), 'latency=1m msg=u_m', map('job', 'api')),
    (toDateTime64('2025-12-31 23:58:07', 9), 'latency=1h msg=u_h', map('job', 'api')),
    (toDateTime64('2025-12-31 23:58:08', 9), 'latency=1m30s msg=compound', map('job', 'api')),
    (toDateTime64('2025-12-31 23:58:09', 9), 'latency=1.5s msg=fractional', map('job', 'api')),
    (toDateTime64('2025-12-31 23:58:10', 9), 'latency=-30s msg=negative', map('job', 'api')),
    (toDateTime64('2025-12-31 23:58:11', 9), 'latency=0 msg=zero', map('job', 'api'));
