-- query.logql --
{job="api"} | unpack | line_format "[{{.pod}}] {{__line__}}"
-- args --
[0] string = "job"
[1] string = "api"
-- sql --
SELECT * FROM `otel_logs` WHERE (`ResourceAttributes`[?] = ?)
-- seed --
CREATE TABLE otel_logs (
    Body String,
    ResourceAttributes Map(String, String) MATERIALIZED map('job', 'api')
) ENGINE = Memory;
INSERT INTO otel_logs (Body) VALUES ('packed body');
-- expected_rows --
[
  ["packed body"]
]
-- chplan --
Filter predicate=(ResourceAttributes["job"] = "api")
  Scan(otel_logs)
