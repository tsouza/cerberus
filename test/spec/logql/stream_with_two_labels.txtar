-- query.logql --
{job="api", env="prod"}
-- sql --
SELECT * FROM `otel_logs` WHERE (`ResourceAttributes`[?] = ?) AND (`ResourceAttributes`[?] = ?)
-- args --
[0] string = "job"
[1] string = "api"
[2] string = "env"
[3] string = "prod"
-- seed --
CREATE TABLE otel_logs (
    Body String,
    ResourceAttributes Map(String, String) MATERIALIZED map('job', 'api', 'env', 'prod')
) ENGINE = Memory;
INSERT INTO otel_logs (Body) VALUES ('hello'), ('world');
-- expected_rows --
[
  ["hello"],
  ["world"]
]
-- chplan --
Filter predicate=((ResourceAttributes["job"] = "api") AND (ResourceAttributes["env"] = "prod"))
  Scan(otel_logs)
