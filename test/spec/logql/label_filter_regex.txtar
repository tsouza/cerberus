-- query.logql --
{job="api"} | env=~"prod|stg"
-- sql --
SELECT * FROM `otel_logs` WHERE (`ResourceAttributes`[?] = ?) AND match(if(mapContains(`LogAttributes`, ?), `LogAttributes`[?], `ResourceAttributes`[?]), ?)
-- args --
[0] string = "job"
[1] string = "api"
[2] string = "env"
[3] string = "env"
[4] string = "env"
[5] string = "prod|stg"
-- seed --
CREATE TABLE otel_logs (
    LogAttributes Map(String, String) MATERIALIZED map(),
    Body String,
    ResourceAttributes Map(String, String) MATERIALIZED map(
        'job', 'api',
        'env', if(Body = 'r1', 'prod', if(Body = 'r2', 'stg', 'dev'))
    )
) ENGINE = Memory;
INSERT INTO otel_logs (Body) VALUES ('r1'), ('r2'), ('r3-dev');
-- expected_rows --
[
  ["r1"],
  ["r2"]
]
-- chplan --
Filter predicate=((ResourceAttributes["job"] = "api") AND (if(mapContains(LogAttributes, "env"), LogAttributes["env"], ResourceAttributes["env"]) =~ "prod|stg"))
  Scan(otel_logs)
