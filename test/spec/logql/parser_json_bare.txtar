-- query.logql --
{job="api"} | json | level="error"
-- sql --
SELECT * FROM `otel_logs` WHERE (`ResourceAttributes`[?] = ?) AND (if(mapContains(mapConcat(`ResourceAttributes`, CAST(JSONExtractKeysAndValues(`Body`, ?), ?)), ?), mapConcat(`ResourceAttributes`, CAST(JSONExtractKeysAndValues(`Body`, ?), ?))[?], `LogAttributes`[?]) = ?)
-- args --
[0] string = "job"
[1] string = "api"
[2] string = "String"
[3] string = "Map(String,String)"
[4] string = "level"
[5] string = "String"
[6] string = "Map(String,String)"
[7] string = "level"
[8] string = "level"
[9] string = "error"
-- seed --
CREATE TABLE otel_logs (
    LogAttributes Map(String, String) MATERIALIZED map(),
    Body String,
    ResourceAttributes Map(String, String) MATERIALIZED map('job', 'api')
) ENGINE = Memory;
INSERT INTO otel_logs (Body) VALUES
    ('{"ts":"2025-01-01","level":"error","msg":"oops"}'),
    ('{"ts":"2025-01-01","level":"info","msg":"skip"}'),
    ('{"ts":"2025-01-01","level":"error","msg":"retry"}');
-- expected_rows --
[
  [{"level": "error", "msg": "oops", "ts": "2025-01-01"}],
  [{"level": "error", "msg": "retry", "ts": "2025-01-01"}]
]
-- chplan --
Filter predicate=((ResourceAttributes["job"] = "api") AND (if(mapContains(mapConcat(ResourceAttributes, CAST(JSONExtractKeysAndValues(Body, "String"), "Map(String,String)")), "level"), mapConcat(ResourceAttributes, CAST(JSONExtractKeysAndValues(Body, "String"), "Map(String,String)"))["level"], LogAttributes["level"]) = "error"))
  Scan(otel_logs)
