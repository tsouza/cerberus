-- query.logql --
{job="api"} | level="error" or level="warn" or level="fatal"
-- args --
[0] string = "job"
[1] string = "api"
[2] string = "level"
[3] string = "level"
[4] string = "level"
[5] string = "error"
[6] string = "level"
[7] string = "level"
[8] string = "level"
[9] string = "warn"
[10] string = "level"
[11] string = "level"
[12] string = "level"
[13] string = "fatal"
-- sql --
SELECT * FROM `otel_logs` WHERE (`ResourceAttributes`[?] = ?) AND (((if(mapContains(`LogAttributes`, ?), `LogAttributes`[?], `ResourceAttributes`[?]) = ?) OR (if(mapContains(`LogAttributes`, ?), `LogAttributes`[?], `ResourceAttributes`[?]) = ?)) OR (if(mapContains(`LogAttributes`, ?), `LogAttributes`[?], `ResourceAttributes`[?]) = ?))
-- seed --
CREATE TABLE otel_logs (
    LogAttributes Map(String, String) MATERIALIZED map(),
    Body String,
    ResourceAttributes Map(String, String) MATERIALIZED map(
        'job', 'api',
        'level',
            if(Body = 'r1-err', 'error',
            if(Body = 'r2-warn', 'warn',
            if(Body = 'r3-fatal', 'fatal',
            if(Body = 'r4-info', 'info', 'debug'))))
    )
) ENGINE = Memory;
INSERT INTO otel_logs (Body) VALUES
    ('r1-err'),
    ('r2-warn'),
    ('r3-fatal'),
    ('r4-info'),
    ('r5-debug');
-- expected_rows --
[
  ["r1-err"],
  ["r2-warn"],
  ["r3-fatal"]
]
-- chplan --
Filter predicate=((ResourceAttributes["job"] = "api") AND (((if(mapContains(LogAttributes, "level"), LogAttributes["level"], ResourceAttributes["level"]) = "error") OR (if(mapContains(LogAttributes, "level"), LogAttributes["level"], ResourceAttributes["level"]) = "warn")) OR (if(mapContains(LogAttributes, "level"), LogAttributes["level"], ResourceAttributes["level"]) = "fatal")))
  Scan(otel_logs)
