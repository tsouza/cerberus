    (toDateTime64('2026-01-01 00:00:00', 9), 'c', map('service_name', 'api', 'level', 'info', 'env', 'prod')),
    (toDateTime64('2025-12-31 23:58:30', 9), 'd', map('service_name', 'api', 'level', 'meta', 'env', 'stage')),
