-- query.logql --
{service_name="cerberus"}
-- seed --
CREATE TABLE otel_logs (
    Timestamp DateTime64(9),
    Body String,
    ResourceAttributes Map(String, String),
    ServiceName String DEFAULT ''
) ENGINE = Memory;
-- Cerberus-self shape: ResourceAttributes empty, ServiceName promoted by
-- the OTel collector → CH exporter. The matcher must still hit the row.
INSERT INTO otel_logs (Timestamp, Body, ResourceAttributes, ServiceName) VALUES
    (toDateTime64('2026-05-20 12:00:00.000000000', 9), 'self-row', map(), 'cerberus');
-- Seed shape: value lives in the underscored map key (Grafana panels +
-- the conformance corpus write this form). The matcher must hit too.
INSERT INTO otel_logs (Timestamp, Body, ResourceAttributes, ServiceName) VALUES
    (toDateTime64('2026-05-20 12:01:00.000000000', 9), 'seed-underscored', map('service_name', 'cerberus'), '');
-- OTel-semantic-convention dotted shape. The map fallback must still
-- resolve when neither the top-level column nor the underscored key
-- carry the value.
INSERT INTO otel_logs (Timestamp, Body, ResourceAttributes, ServiceName) VALUES
    (toDateTime64('2026-05-20 12:02:00.000000000', 9), 'seed-dotted', map('service.name', 'cerberus'), '');
-- Negative: a row with a different service name. Must NOT match.
INSERT INTO otel_logs (Timestamp, Body, ResourceAttributes, ServiceName) VALUES
    (toDateTime64('2026-05-20 12:03:00.000000000', 9), 'other-row', map('service_name', 'other'), 'other');
-- expected_rows --
[
  ["2026-05-20T12:00:00Z", "self-row", {}, "cerberus"],
  ["2026-05-20T12:01:00Z", "seed-underscored", {"service_name":"cerberus"}, ""],
  ["2026-05-20T12:02:00Z", "seed-dotted", {"service.name":"cerberus"}, ""]
]
-- args --
[0] string = ""
[1] string = "service_name"
[2] string = "service_name"
[3] string = "service.name"
[4] string = "cerberus"
-- chplan --
Filter predicate=(coalesce(nullIf(ServiceName, ""), if(mapContains(ResourceAttributes, "service_name"), ResourceAttributes["service_name"], ResourceAttributes["service.name"])) = "cerberus")
  Scan(otel_logs)
-- sql --
SELECT * FROM `otel_logs` WHERE (coalesce(nullIf(`ServiceName`, ?), if(mapContains(`ResourceAttributes`, ?), `ResourceAttributes`[?], `ResourceAttributes`[?])) = ?)
