-- seed --
CREATE TABLE otel_logs (
    LogAttributes Map(String, String) MATERIALIZED map(),
    Body String,
    ResourceAttributes Map(String, String) MATERIALIZED map('job', 'api')
) ENGINE = Memory;
INSERT INTO otel_logs (Body) VALUES
    ('latency=291.792µs msg=keep_micro_sign'),
    ('latency=300μs msg=keep_greek_mu'),
    ('latency=100µs msg=drop_small'),
    ('latency=2ms msg=keep_ms'),
    ('latency=oops msg=keep_error'),
    ('msg=no_latency');
