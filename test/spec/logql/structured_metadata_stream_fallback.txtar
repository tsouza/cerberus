-- query.logql --
{service_name="clickhouse"} | region="us-east"
-- seed --
CREATE TABLE otel_logs (
    ServiceName LowCardinality(String) DEFAULT 'clickhouse',
    Body String,
    ResourceAttributes Map(String, String) MATERIALIZED map(
        'service_name', 'clickhouse',
        'region', if(Body LIKE 'e%', 'us-east', 'us-west')
    ),
    LogAttributes Map(String, String) MATERIALIZED map(
        'query_kind', 'Select'
    )
) ENGINE = Memory;
INSERT INTO otel_logs (Body) VALUES ('e1'), ('e2'), ('w1');
-- expected_rows --
[
  ["clickhouse", "e1"],
  ["clickhouse", "e2"]
]
-- chplan --
Filter predicate=((coalesce(nullIf(ServiceName, ""), if(mapContains(ResourceAttributes, "service_name"), ResourceAttributes["service_name"], if(mapContains(ResourceAttributes, "service.name"), ResourceAttributes["service.name"], ResourceAttributes["service/name"]))) = "clickhouse") AND (if(mapContains(LogAttributes, "region"), LogAttributes["region"], ResourceAttributes["region"]) = "us-east"))
  Scan(otel_logs)
-- sql --
SELECT * FROM `otel_logs` WHERE (coalesce(nullIf(`ServiceName`, ?), if(mapContains(`ResourceAttributes`, ?), `ResourceAttributes`[?], if(mapContains(`ResourceAttributes`, ?), `ResourceAttributes`[?], `ResourceAttributes`[?]))) = ?) AND (if(mapContains(`LogAttributes`, ?), `LogAttributes`[?], `ResourceAttributes`[?]) = ?)
-- args --
[0] string = ""
[1] string = "service_name"
[2] string = "service_name"
[3] string = "service.name"
[4] string = "service.name"
[5] string = "service/name"
[6] string = "clickhouse"
[7] string = "region"
[8] string = "region"
[9] string = "region"
[10] string = "us-east"
