-- query.logql --
{job="api"}
-- sql --
SELECT * FROM `otel_logs` WHERE (`ResourceAttributes`[?] = ?)
-- args --
[0] string = "job"
[1] string = "api"
-- seed --
CREATE TABLE otel_logs (
    Body String,
    ResourceAttributes Map(String, String) MATERIALIZED map('job', if(Body = 'beta', 'other', 'api'))
) ENGINE = Memory;
INSERT INTO otel_logs (Body) VALUES ('alpha'), ('beta'), ('gamma');
-- expected_rows --
[
  ["alpha"],
  ["gamma"]
]
-- chplan --
Filter predicate=(ResourceAttributes["job"] = "api")
  Scan(otel_logs)
