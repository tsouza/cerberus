-- query.logql --
{job="api"} | env="prod" or env="stg"
-- sql --
SELECT * FROM `otel_logs` WHERE (`ResourceAttributes`[?] = ?) AND ((`ResourceAttributes`[?] = ?) OR (`ResourceAttributes`[?] = ?))
-- args --
[0] string = "job"
[1] string = "api"
[2] string = "env"
[3] string = "prod"
[4] string = "env"
[5] string = "stg"
