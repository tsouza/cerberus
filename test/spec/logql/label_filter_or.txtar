-- query.logql --
{job="api"} | env="prod" or env="stg"
-- sql --
SELECT * FROM `otel_logs` WHERE (`ResourceAttributes`[?] = ?) AND ((if(mapContains(`LogAttributes`, ?), `LogAttributes`[?], `ResourceAttributes`[?]) = ?) OR (if(mapContains(`LogAttributes`, ?), `LogAttributes`[?], `ResourceAttributes`[?]) = ?))
-- args --
[0] string = "job"
[1] string = "api"
[2] string = "env"
[3] string = "env"
[4] string = "env"
[5] string = "prod"
[6] string = "env"
[7] string = "env"
[8] string = "env"
[9] string = "stg"
-- seed --
CREATE TABLE otel_logs (
    LogAttributes Map(String, String) MATERIALIZED map(),
    Body String,
    ResourceAttributes Map(String, String) MATERIALIZED map(
        'job', 'api',
        'env', if(Body = 'o1', 'prod', if(Body = 'o2', 'stg', 'dev'))
    )
) ENGINE = Memory;
INSERT INTO otel_logs (Body) VALUES ('o1'), ('o2'), ('o3-dev');
-- expected_rows --
[
  ["o1"],
  ["o2"]
]
-- chplan --
Filter predicate=((ResourceAttributes["job"] = "api") AND ((if(mapContains(LogAttributes, "env"), LogAttributes["env"], ResourceAttributes["env"]) = "prod") OR (if(mapContains(LogAttributes, "env"), LogAttributes["env"], ResourceAttributes["env"]) = "stg")))
  Scan(otel_logs)
