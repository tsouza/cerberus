CREATE TABLE otel_logs (
    LogAttributes Map(String, String),
    Timestamp DateTime64(9),
    Body String,
    SeverityText LowCardinality(String) DEFAULT '',
    ResourceAttributes Map(String, String),
    ServiceName String DEFAULT ''
) ENGINE = Memory;
