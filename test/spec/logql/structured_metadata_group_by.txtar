2026-01-01T00:00:00Z
-- end --
2026-01-01T00:00:00Z
-- step --
1m
-- seed --
CREATE TABLE otel_logs (
    ServiceName LowCardinality(String) DEFAULT 'clickhouse',
    Timestamp DateTime64(9),
    Body String,
    SeverityText LowCardinality(String) DEFAULT '',
    ResourceAttributes Map(String, String),
    LogAttributes Map(String, String)
) ENGINE = Memory;
INSERT INTO otel_logs (Timestamp, Body, LogAttributes) VALUES
    (toDateTime64('2026-01-01 00:00:00', 9), 'q1', map('query_kind', 'Select')),
    (toDateTime64('2026-01-01 00:00:00', 9), 'q2', map('query_kind', 'Select')),
    (toDateTime64('2026-01-01 00:00:00', 9), 'q3', map('query_kind', 'Insert'));
