-- query.logql --
{job="api"} | logfmt | size > 5MB
-- seed --
CREATE TABLE otel_logs (
    LogAttributes Map(String, String) MATERIALIZED map(),
    Body String,
    ResourceAttributes Map(String, String) MATERIALIZED map('job', 'api')
) ENGINE = Memory;
INSERT INTO otel_logs (Body) VALUES
    ('ts=2026-01-01 size=1MB msg="small"'),
    ('ts=2026-01-01 size=9MB msg="big"'),
    ('ts=2026-01-01 size=huge msg="bad_number"'),
    ('ts=2026-01-01 size=10ZB msg="bad_unit"'),
    ('ts=2026-01-01 msg="no_size"');
-- expected_rows --
[
  ["ts=2026-01-01 size=10ZB msg=\"bad_unit\""],
  ["ts=2026-01-01 size=9MB msg=\"big\""],
  ["ts=2026-01-01 size=huge msg=\"bad_number\""]
]
