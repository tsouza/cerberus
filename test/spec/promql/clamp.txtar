-- query.promql --
clamp(temperature, 0, 100)
-- sql --
SELECT `MetricName`, `Attributes`, `TimeUnix`, greatest(?, least(?, `Value`)) AS `Value` FROM (SELECT * FROM (SELECT * FROM `otel_metrics_gauge`) WHERE (`MetricName` = ?))
-- args --
[0] float64 = 0
[1] float64 = 100
[2] string = "temperature"
