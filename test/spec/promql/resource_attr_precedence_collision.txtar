# rc.5 (audit) â€” precedence parity on a DOTTED key present in BOTH maps.
# `k8s.namespace.name` is in Attributes ('override') AND in
# ResourceAttributes ('prod'). The read-path projection sanitizes BOTH maps'
# keys before mapUpdate, so both sides spell the key `k8s_namespace_name`,
# the collision is exact, and the per-datapoint Attributes value WINS.
#
# This pins the fix for the audit bug: sanitizing only the RA side let the
# dotted Attributes key dodge the collision â€” RA would win the projected
# value AND a phantom Prom-illegal `k8s.namespace.name` label would leak,
# while the matcher made Attributes win. Asserting via -- expected_rows --:
# the output label `k8s_namespace_name` == 'override' and NO dotted
# `k8s.namespace.name` label appears.

-- query.promql --
http_requests_total
-- seed --
CREATE TABLE otel_metrics_sum (
    MetricName String,
    Attributes Map(String, String),
    ResourceAttributes Map(String, String),
    TimeUnix DateTime64(9),
    Value Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
INSERT INTO otel_metrics_sum VALUES
    ('http_requests_total', map('k8s.namespace.name', 'override'), map('k8s.namespace.name', 'prod'), toDateTime64('2026-01-01 00:00:00', 9), 5.0);
-- expected_rows --
[
  ["http_requests_total", {"k8s_namespace_name": "override"}, "2026-01-01T00:00:00Z", 5.0]
]
-- args --
[0] string = "service.name"
[1] string = "service_name"
[2] string = "service.name"
[3] string = "service_name"
[4] string = "http_requests_total"
[5] string = "http.requests.total"
[6] string = "http.requests/total"
[7] string = "http.requests_total"
[8] string = "http/requests/total"
[9] string = "http/requests_total"
[10] string = "http_requests.total"
[11] string = "2026-01-01 00:00:01.000000000"
[12] int64 = 9
[13] string = "2026-01-01 00:00:01.000000000"
[14] int64 = 9
[15] int64 = 300000000000
-- chplan --
Project [MetricName AS MetricName, Attributes AS Attributes, lwr_ts AS TimeUnix, lwr_value AS Value]
  Aggregate groupBy=[MetricName AS MetricName, Attributes AS Attributes] funcs=[max(TimeUnix) AS lwr_ts, argMax(Value, TimeUnix) AS lwr_value]
    Filter predicate=((TimeUnix <= toDateTime64("2026-01-01 00:00:01.000000000", 9)) AND (TimeUnix > (toDateTime64("2026-01-01 00:00:01.000000000", 9) - toIntervalNanosecond(300000000000))))
      Project [MetricName AS MetricName, mapUpdate(mapFromArrays(arrayMap(k -> replaceRegexpAll(k, "[^a-zA-Z0-9_]", "_"), mapKeys(mapFilter((k, v) -> (k NOT IN ("service.name", "service_name")), ResourceAttributes))), mapValues(mapFilter((k, v) -> (k NOT IN ("service.name", "service_name")), ResourceAttributes))), mapFromArrays(arrayMap(k -> replaceRegexpAll(k, "[^a-zA-Z0-9_]", "_"), mapKeys(Attributes)), mapValues(Attributes))) AS Attributes, TimeUnix AS TimeUnix, Value AS Value]
        Filter predicate=(MetricName IN ("http_requests_total", "http.requests.total", "http.requests/total", "http.requests_total", "http/requests/total", "http/requests_total", "http_requests.total"))
          Scan(otel_metrics_sum)
-- sql --
SELECT `MetricName` AS `MetricName`, `Attributes` AS `Attributes`, `lwr_ts` AS `TimeUnix`, `lwr_value` AS `Value` FROM (SELECT `MetricName` AS `MetricName`, `Attributes` AS `Attributes`, max(`TimeUnix`) AS `lwr_ts`, argMax(`Value`, `TimeUnix`) AS `lwr_value` FROM (SELECT * FROM (SELECT `MetricName` AS `MetricName`, mapUpdate(mapFromArrays(arrayMap(k -> replaceRegexpAll(k, '[^a-zA-Z0-9_]', '_'), mapKeys(mapFilter((k, v) -> (k NOT IN (?, ?)), `ResourceAttributes`))), mapValues(mapFilter((k, v) -> (k NOT IN (?, ?)), `ResourceAttributes`))), mapFromArrays(arrayMap(k -> replaceRegexpAll(k, '[^a-zA-Z0-9_]', '_'), mapKeys(`Attributes`)), mapValues(`Attributes`))) AS `Attributes`, `TimeUnix` AS `TimeUnix`, `Value` AS `Value` FROM (SELECT * FROM `otel_metrics_sum` WHERE (`MetricName` IN (?, ?, ?, ?, ?, ?, ?)))) WHERE ((`TimeUnix` <= toDateTime64(?, ?)) AND (`TimeUnix` > (toDateTime64(?, ?) - toIntervalNanosecond(?))))) GROUP BY `MetricName`, `Attributes`)
