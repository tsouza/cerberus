-- query.promql --
http_server_request_a_total unless http_server_request_b_total
-- seed --
CREATE TABLE otel_metrics_sum (
    MetricName String,
    Attributes Map(String, String),
    TimeUnix DateTime64(9),
    Value Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
INSERT INTO otel_metrics_sum VALUES
    ('http_server_request_a_total', map('job', 'api'),   toDateTime64('2026-01-01 00:00:00', 9), 10.0),
    ('http_server_request_a_total', map('job', 'other'), toDateTime64('2026-01-01 00:00:00', 9), 20.0),
    ('http_server_request_b_total',   map('job', 'api'),   toDateTime64('2026-01-01 00:00:00', 9), 25.0);
