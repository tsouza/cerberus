    ('up', map('job', 'node', 'instance', 'a'), toDateTime64('2026-01-01 00:00:00', 9), 3.0),
    ('up', map('job', 'node', 'instance', 'b'), toDateTime64('2026-01-01 00:00:00', 9), 4.0);
