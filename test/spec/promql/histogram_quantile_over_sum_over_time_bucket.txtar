-- query.promql --
histogram_quantile(0.99, sum by (le)(sum_over_time(loadbalancing_googleapis_com_https_total_latencies_bucket[5m])))
-- seed --
CREATE TABLE otel_metrics_histogram (
    MetricName String, Attributes Map(String, String), ResourceAttributes Map(String, String),
    TimeUnix DateTime64(9), Count UInt64, Sum Float64,
    BucketCounts Array(UInt64), ExplicitBounds Array(Float64)
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
CREATE TABLE otel_metrics_sum (
    MetricName String, Attributes Map(String, String), ResourceAttributes Map(String, String),
    TimeUnix DateTime64(9), Value Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
CREATE TABLE otel_metrics_gauge (
    MetricName String, Attributes Map(String, String), ResourceAttributes Map(String, String),
    TimeUnix DateTime64(9), Value Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
INSERT INTO otel_metrics_histogram VALUES
    ('loadbalancing_googleapis_com_https_total_latencies', map('lb','a'), map(), toDateTime64('2025-12-31 23:59:30', 9), 10, 5.0,  [3,4,3], [0.1,0.5,1.0]),
    ('loadbalancing_googleapis_com_https_total_latencies', map('lb','a'), map(), toDateTime64('2026-01-01 00:00:00', 9), 70, 35.0, [21,28,21], [0.1,0.5,1.0]);
-- expected_rows --
[
  ["", {}, "2026-01-01T00:00:01Z", 1]
]
-- description --
Regression (rc.8 Issue B): histogram_quantile over sum by(le)(sum_over_time(
_bucket[5m])) for a DELTA histogram. matchHistogramAggIdiom only recognised
rate/increase as the inner bucket aggregation, so the sum_over_time form fell to
the non-bucket fallback (Filter(input,false)) → empty. The fix adds sum_over_time
to the idiom (scale-invariant: histogram_quantile interpolates cumulative-count
RATIOS, so DELTA-histogram sum_over_time aggregation is the canonical shape). The
inner agg returns le-keyed bucket series; the quantile interpolates rather than
collapsing to empty. p99 lands in the top (>=1.0/+Inf) bucket.
