-- chplan --
Project ["" AS MetricName, Attributes AS Attributes, now64(9) AS TimeUnix, Value AS Value]
  HistogramQuantile phi=0.99 groupBy=[Attributes AS Attributes]
    Project [CAST(map(), "Map(String,String)") AS Attributes, BucketCounts AS BucketCounts, ExplicitBounds AS ExplicitBounds]
      Aggregate groupBy=[] funcs=[sumForEach(BucketCounts) AS BucketCounts, any(ExplicitBounds) AS ExplicitBounds]
        Filter predicate=(((MetricName IN ("loadbalancing_googleapis_com_https_total_latencies", "loadbalancing.googleapis.com.https.total.latencies", "loadbalancing.googleapis.com.https.total/latencies", "loadbalancing.googleapis.com.https.total_latencies", "loadbalancing.googleapis.com.https/total/latencies", "loadbalancing.googleapis.com.https/total_latencies", "loadbalancing.googleapis.com.https_total.latencies", "loadbalancing.googleapis.com.https_total_latencies", "loadbalancing.googleapis.com/https/total/latencies", "loadbalancing.googleapis.com/https/total_latencies", "loadbalancing.googleapis.com/https_total_latencies", "loadbalancing.googleapis.com_https.total.latencies", "loadbalancing.googleapis.com_https.total_latencies", "loadbalancing.googleapis.com_https_total.latencies", "loadbalancing.googleapis.com_https_total_latencies", "loadbalancing.googleapis/com/https/total/latencies", "loadbalancing.googleapis/com/https/total_latencies", "loadbalancing.googleapis/com/https_total_latencies", "loadbalancing.googleapis/com_https_total_latencies", "loadbalancing.googleapis_com.https.total.latencies", "loadbalancing.googleapis_com.https.total_latencies", "loadbalancing.googleapis_com.https_total.latencies", "loadbalancing.googleapis_com.https_total_latencies", "loadbalancing.googleapis_com_https.total.latencies", "loadbalancing.googleapis_com_https.total_latencies", "loadbalancing.googleapis_com_https_total.latencies", "loadbalancing.googleapis_com_https_total_latencies", "loadbalancing/googleapis/com/https/total/latencies", "loadbalancing/googleapis/com/https/total_latencies", "loadbalancing/googleapis/com/https_total_latencies", "loadbalancing/googleapis/com_https_total_latencies", "loadbalancing/googleapis_com_https_total_latencies", "loadbalancing_googleapis.com.https.total.latencies", "loadbalancing_googleapis.com.https.total_latencies", "loadbalancing_googleapis.com.https_total.latencies", "loadbalancing_googleapis.com.https_total_latencies", "loadbalancing_googleapis.com_https.total.latencies", "loadbalancing_googleapis.com_https.total_latencies", "loadbalancing_googleapis.com_https_total.latencies", "loadbalancing_googleapis.com_https_total_latencies", "loadbalancing_googleapis_com.https.total.latencies", "loadbalancing_googleapis_com.https.total_latencies", "loadbalancing_googleapis_com.https_total.latencies", "loadbalancing_googleapis_com.https_total_latencies", "loadbalancing_googleapis_com_https.total.latencies", "loadbalancing_googleapis_com_https.total_latencies", "loadbalancing_googleapis_com_https_total.latencies")) AND (TimeUnix <= toDateTime64("2026-01-01 00:00:01.000000000", 9))) AND (TimeUnix > (toDateTime64("2026-01-01 00:00:01.000000000", 9) - toIntervalNanosecond(300000000000))))
          Scan(otel_metrics_histogram)
-- sql --
SELECT ? AS `MetricName`, `Attributes` AS `Attributes`, now64(?) AS `TimeUnix`, `Value` AS `Value` FROM (SELECT `Attributes` AS `Attributes`, if(length(`BucketCounts`) = 0, nan, if(arraySum(arrayMap(x -> toFloat64(x), `BucketCounts`)) = 0, nan, if(0.99 <= 0, 0.0, if(0.99 >= 1, `ExplicitBounds`[length(`ExplicitBounds`)], if(arrayFirstIndex(c -> c >= (0.99 * arraySum(arrayMap(x -> toFloat64(x), `BucketCounts`))), arrayCumSum(arrayMap(x -> toFloat64(x), `BucketCounts`))) = length(arrayCumSum(arrayMap(x -> toFloat64(x), `BucketCounts`))), `ExplicitBounds`[length(`ExplicitBounds`)], (if(arrayFirstIndex(c -> c >= (0.99 * arraySum(arrayMap(x -> toFloat64(x), `BucketCounts`))), arrayCumSum(arrayMap(x -> toFloat64(x), `BucketCounts`))) = 1, 0.0, `ExplicitBounds`[arrayFirstIndex(c -> c >= (0.99 * arraySum(arrayMap(x -> toFloat64(x), `BucketCounts`))), arrayCumSum(arrayMap(x -> toFloat64(x), `BucketCounts`))) - 1]) + (`ExplicitBounds`[arrayFirstIndex(c -> c >= (0.99 * arraySum(arrayMap(x -> toFloat64(x), `BucketCounts`))), arrayCumSum(arrayMap(x -> toFloat64(x), `BucketCounts`)))] - if(arrayFirstIndex(c -> c >= (0.99 * arraySum(arrayMap(x -> toFloat64(x), `BucketCounts`))), arrayCumSum(arrayMap(x -> toFloat64(x), `BucketCounts`))) = 1, 0.0, `ExplicitBounds`[arrayFirstIndex(c -> c >= (0.99 * arraySum(arrayMap(x -> toFloat64(x), `BucketCounts`))), arrayCumSum(arrayMap(x -> toFloat64(x), `BucketCounts`))) - 1])) * ((0.99 * arraySum(arrayMap(x -> toFloat64(x), `BucketCounts`))) - if(arrayFirstIndex(c -> c >= (0.99 * arraySum(arrayMap(x -> toFloat64(x), `BucketCounts`))), arrayCumSum(arrayMap(x -> toFloat64(x), `BucketCounts`))) = 1, 0.0, arrayCumSum(arrayMap(x -> toFloat64(x), `BucketCounts`))[arrayFirstIndex(c -> c >= (0.99 * arraySum(arrayMap(x -> toFloat64(x), `BucketCounts`))), arrayCumSum(arrayMap(x -> toFloat64(x), `BucketCounts`))) - 1])) / (arrayCumSum(arrayMap(x -> toFloat64(x), `BucketCounts`))[arrayFirstIndex(c -> c >= (0.99 * arraySum(arrayMap(x -> toFloat64(x), `BucketCounts`))), arrayCumSum(arrayMap(x -> toFloat64(x), `BucketCounts`)))] - if(arrayFirstIndex(c -> c >= (0.99 * arraySum(arrayMap(x -> toFloat64(x), `BucketCounts`))), arrayCumSum(arrayMap(x -> toFloat64(x), `BucketCounts`))) = 1, 0.0, arrayCumSum(arrayMap(x -> toFloat64(x), `BucketCounts`))[arrayFirstIndex(c -> c >= (0.99 * arraySum(arrayMap(x -> toFloat64(x), `BucketCounts`))), arrayCumSum(arrayMap(x -> toFloat64(x), `BucketCounts`))) - 1])))))))) AS `Value` FROM (SELECT CAST(map(), ?) AS `Attributes`, `BucketCounts` AS `BucketCounts`, `ExplicitBounds` AS `ExplicitBounds` FROM (SELECT `BucketCounts`, `ExplicitBounds` FROM (SELECT sumForEach(`BucketCounts`) AS `BucketCounts`, any(`ExplicitBounds`) AS `ExplicitBounds`, count() AS `_cerb_n` FROM (SELECT * FROM `otel_metrics_histogram` PREWHERE (`MetricName` IN (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)) WHERE (`TimeUnix` <= toDateTime64(?, ?)) AND (`TimeUnix` > (toDateTime64(?, ?) - toIntervalNanosecond(?))))) WHERE `_cerb_n` > 0)))
