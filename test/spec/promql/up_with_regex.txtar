-- query.promql --
up{job=~"api-.*"}
-- args --
[0] string = "up"
[1] string = "job"
[2] string = "api-.*"
-- sql --
SELECT * FROM `otel_metrics_gauge` PREWHERE (`MetricName` = ?) WHERE match(`Attributes`[?], ?)
-- chplan --
Filter predicate=((Attributes["job"] =~ "api-.*") AND (MetricName = "up"))
  Scan(otel_metrics_gauge)
