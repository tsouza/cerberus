-- query.promql --
100 < temperature
-- sql --
SELECT * FROM (SELECT * FROM `otel_metrics_gauge` WHERE (`MetricName` = ?)) WHERE (? < `Value`)
-- args --
[0] string = "temperature"
[1] float64 = 100
-- chplan --
Filter predicate=(100 < Value)
  Filter predicate=(MetricName = "temperature")
    Scan(otel_metrics_gauge)
