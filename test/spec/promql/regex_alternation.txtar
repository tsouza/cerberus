-- query.promql --
up{job=~"api|web"}
-- sql --
SELECT * FROM `otel_metrics_gauge` PREWHERE (`MetricName` = ?) WHERE match(`Attributes`[?], ?)
-- args --
[0] string = "up"
[1] string = "job"
[2] string = "api|web"
-- chplan --
Filter predicate=((Attributes["job"] =~ "api|web") AND (MetricName = "up"))
  Scan(otel_metrics_gauge)
