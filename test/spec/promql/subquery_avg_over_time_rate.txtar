[
  [{"job": "api"}, "2026-01-01T00:00:00Z", 0.14814814814814814],
  [{"job": "api"}, "2026-01-01T00:00:30Z", 0.15625],
  [{"job": "api"}, "2026-01-01T00:01:00Z", 0.16666666666666666],
