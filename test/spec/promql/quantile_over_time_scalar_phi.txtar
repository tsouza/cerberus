-- query.promql --
quantile_over_time(scalar(threshold), up{job="api", instance="a"}[5m])
-- seed --
CREATE TABLE otel_metrics_gauge (
    MetricName String,
    Attributes Map(String, String),
    TimeUnix DateTime64(9),
    Value Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
INSERT INTO otel_metrics_gauge VALUES
    ('up', map('job', 'api', 'instance', 'a'), toDateTime64('2025-12-31 23:56:00', 9), 0.1),
    ('up', map('job', 'api', 'instance', 'a'), toDateTime64('2025-12-31 23:58:00', 9), 0.3),
    ('up', map('job', 'api', 'instance', 'a'), toDateTime64('2026-01-01 00:00:00', 9), 0.5);
INSERT INTO otel_metrics_gauge VALUES
    ('threshold', map('env', 'prod'), toDateTime64('2026-01-01 00:00:00', 9), 0.5);
