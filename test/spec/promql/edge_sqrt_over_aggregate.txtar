-- query.promql --
sqrt(avg(latency_seconds))
-- args --
[0] string = ""
[1] string = ""
[2] string = "Map(String,String)"
[3] int64 = 9
[4] string = "latency_seconds"
[5] string = "latency.seconds"
[6] string = "2026-01-01 00:00:01.000000000"
[7] int64 = 9
[8] string = "2026-01-01 00:00:01.000000000"
[9] int64 = 9
[10] int64 = 300000000000
-- sql --
SELECT ? AS `MetricName`, `Attributes`, `TimeUnix`, sqrt(`Value`) AS `Value` FROM (SELECT ? AS `MetricName`, CAST(map(), ?) AS `Attributes`, now64(?) AS `TimeUnix`, `Value` AS `Value` FROM (SELECT `Value` FROM (SELECT avg(`Value`) AS `Value`, count() AS `_cerb_n` FROM (SELECT `MetricName` AS `MetricName`, `Attributes` AS `Attributes`, `lwr_ts` AS `TimeUnix`, `lwr_value` AS `Value` FROM (SELECT `MetricName` AS `MetricName`, `Attributes` AS `Attributes`, max(`TimeUnix`) AS `lwr_ts`, argMax(`Value`, `TimeUnix`) AS `lwr_value` FROM (SELECT * FROM merge(currentDatabase(), '^(otel_metrics_gauge|otel_metrics_sum)$') PREWHERE ((`MetricName` = ?) OR (`MetricName` = ?)) WHERE (`TimeUnix` <= toDateTime64(?, ?)) AND (`TimeUnix` > (toDateTime64(?, ?) - toIntervalNanosecond(?)))) GROUP BY `MetricName`, `Attributes`))) WHERE `_cerb_n` > 0))
-- chplan --
Project ["" AS MetricName, Attributes, TimeUnix, sqrt(Value) AS Value]
  Project ["" AS MetricName, CAST(map(), "Map(String,String)") AS Attributes, now64(9) AS TimeUnix, Value AS Value]
    Aggregate groupBy=[] funcs=[avg(Value) AS Value]
      Project [MetricName AS MetricName, Attributes AS Attributes, lwr_ts AS TimeUnix, lwr_value AS Value]
        Aggregate groupBy=[MetricName AS MetricName, Attributes AS Attributes] funcs=[max(TimeUnix) AS lwr_ts, argMax(Value, TimeUnix) AS lwr_value]
          Filter predicate=((((MetricName = "latency_seconds") OR (MetricName = "latency.seconds")) AND (TimeUnix <= toDateTime64("2026-01-01 00:00:01.000000000", 9))) AND (TimeUnix > (toDateTime64("2026-01-01 00:00:01.000000000", 9) - toIntervalNanosecond(300000000000))))
            Scan(merge(otel_metrics_gauge|otel_metrics_sum))
-- seed --
CREATE TABLE otel_metrics_gauge (
    MetricName String,
    Attributes Map(String, String),
    TimeUnix DateTime64(9),
    Value Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
INSERT INTO otel_metrics_gauge VALUES
    ('latency_seconds', map('endpoint', 'a'), toDateTime64('2026-01-01 00:00:00', 9), 9.0),
    ('latency_seconds', map('endpoint', 'b'), toDateTime64('2026-01-01 00:00:00', 9), 16.0);
