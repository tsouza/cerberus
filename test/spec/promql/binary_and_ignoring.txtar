-- query.promql --
http_server_request_duration_count and ignoring(instance) http_server_request_duration_sum
-- seed --
CREATE TABLE otel_metrics_sum (
    MetricName String,
    Attributes Map(String, String),
    TimeUnix DateTime64(9),
    Value Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
INSERT INTO otel_metrics_sum VALUES
    ('http_server_request_duration_count', map('job', 'api', 'instance', 'i-1'), toDateTime64('2026-01-01 00:00:00', 9), 10.0),
    ('http_server_request_duration_sum',   map('job', 'api', 'instance', 'i-2'), toDateTime64('2026-01-01 00:00:00', 9), 25.0);
-- expected_rows --
[
  ["http_server_request_duration_count", {"instance": "i-1", "job": "api"}, "2026-01-01T00:00:00Z", 10]
]
-- args --
[0] string = "http_server_request_duration_count"
