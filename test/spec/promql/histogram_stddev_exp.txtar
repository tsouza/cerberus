-- chplan --
Project ["" AS MetricName, Attributes AS Attributes, now64(9) AS TimeUnix, sqrt((((arraySum(arrayMap((c, i) -> (toFloat64(c) * ((pow(pow(2, pow(2, (0 - toFloat64(Scale)))), ((PositiveOffset + (i - 1)) + 0.5)) - (Sum / toFloat64(Count))) * (pow(pow(2, pow(2, (0 - toFloat64(Scale)))), ((PositiveOffset + (i - 1)) + 0.5)) - (Sum / toFloat64(Count))))), PositiveBucketCounts, arrayEnumerate(PositiveBucketCounts))) + arraySum(arrayMap((c, i) -> (toFloat64(c) * (((0 - pow(pow(2, pow(2, (0 - toFloat64(Scale)))), ((NegativeOffset + (i - 1)) + 0.5))) - (Sum / toFloat64(Count))) * ((0 - pow(pow(2, pow(2, (0 - toFloat64(Scale)))), ((NegativeOffset + (i - 1)) + 0.5))) - (Sum / toFloat64(Count))))), NegativeBucketCounts, arrayEnumerate(NegativeBucketCounts)))) + (toFloat64(ZeroCount) * ((Sum / toFloat64(Count)) * (Sum / toFloat64(Count))))) / toFloat64(Count))) AS Value]
  Aggregate groupBy=[Attributes AS Attributes] funcs=[argMax(Count, TimeUnix) AS Count, argMax(Sum, TimeUnix) AS Sum, argMax(Scale, TimeUnix) AS Scale, argMax(ZeroCount, TimeUnix) AS ZeroCount, argMax(PositiveOffset, TimeUnix) AS PositiveOffset, argMax(PositiveBucketCounts, TimeUnix) AS PositiveBucketCounts, argMax(NegativeOffset, TimeUnix) AS NegativeOffset, argMax(NegativeBucketCounts, TimeUnix) AS NegativeBucketCounts]
    Filter predicate=(MetricName IN ("latency_exp_hist", "latency.exp.hist", "latency.exp/hist", "latency.exp_hist", "latency/exp/hist", "latency/exp_hist", "latency_exp.hist"))
      Scan(otel_metrics_exponential_histogram)
-- sql --
SELECT ? AS `MetricName`, `Attributes` AS `Attributes`, now64(?) AS `TimeUnix`, sqrt((((arraySum(arrayMap((c, i) -> (toFloat64(c) * ((pow(pow(toFloat64(?), pow(toFloat64(?), (toFloat64(?) - toFloat64(`Scale`)))), ((`PositiveOffset` + (i - toFloat64(?))) + toFloat64(?))) - (`Sum` / toFloat64(`Count`))) * (pow(pow(toFloat64(?), pow(toFloat64(?), (toFloat64(?) - toFloat64(`Scale`)))), ((`PositiveOffset` + (i - toFloat64(?))) + toFloat64(?))) - (`Sum` / toFloat64(`Count`))))), `PositiveBucketCounts`, arrayEnumerate(`PositiveBucketCounts`))) + arraySum(arrayMap((c, i) -> (toFloat64(c) * (((toFloat64(?) - pow(pow(toFloat64(?), pow(toFloat64(?), (toFloat64(?) - toFloat64(`Scale`)))), ((`NegativeOffset` + (i - toFloat64(?))) + toFloat64(?)))) - (`Sum` / toFloat64(`Count`))) * ((toFloat64(?) - pow(pow(toFloat64(?), pow(toFloat64(?), (toFloat64(?) - toFloat64(`Scale`)))), ((`NegativeOffset` + (i - toFloat64(?))) + toFloat64(?)))) - (`Sum` / toFloat64(`Count`))))), `NegativeBucketCounts`, arrayEnumerate(`NegativeBucketCounts`)))) + (toFloat64(`ZeroCount`) * ((`Sum` / toFloat64(`Count`)) * (`Sum` / toFloat64(`Count`))))) / toFloat64(`Count`))) AS `Value` FROM (SELECT `Attributes` AS `Attributes`, argMax(`Count`, `TimeUnix`) AS `Count`, argMax(`Sum`, `TimeUnix`) AS `Sum`, argMax(`Scale`, `TimeUnix`) AS `Scale`, argMax(`ZeroCount`, `TimeUnix`) AS `ZeroCount`, argMax(`PositiveOffset`, `TimeUnix`) AS `PositiveOffset`, argMax(`PositiveBucketCounts`, `TimeUnix`) AS `PositiveBucketCounts`, argMax(`NegativeOffset`, `TimeUnix`) AS `NegativeOffset`, argMax(`NegativeBucketCounts`, `TimeUnix`) AS `NegativeBucketCounts` FROM (SELECT * FROM `otel_metrics_exponential_histogram` WHERE (`MetricName` IN (?, ?, ?, ?, ?, ?, ?))) GROUP BY `Attributes`)
