-- query.promql --
sum(sum_over_time(loadbalancing_googleapis_com_https_request_count[5m])) / 300
-- seed --
CREATE TABLE otel_metrics_histogram (
    MetricName String, Attributes Map(String, String), ResourceAttributes Map(String, String),
    TimeUnix DateTime64(9), Count UInt64, Sum Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
CREATE TABLE otel_metrics_sum (
    MetricName String, Attributes Map(String, String), ResourceAttributes Map(String, String),
    TimeUnix DateTime64(9), Value Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
CREATE TABLE otel_metrics_gauge (
    MetricName String, Attributes Map(String, String), ResourceAttributes Map(String, String),
    TimeUnix DateTime64(9), Value Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
INSERT INTO otel_metrics_sum VALUES
    ('loadbalancing_googleapis_com_https_request_count', map('lb','a'), map(), toDateTime64('2025-12-31 23:59:30', 9), 150),
    ('loadbalancing_googleapis_com_https_request_count', map('lb','a'), map(), toDateTime64('2026-01-01 00:00:00', 9), 150);
-- expected_rows --
[
  ["", {}, "2026-01-01T00:00:01Z", 1]
]
-- description --
Regression (rc.8 Issue C control): an AGGREGATED range-vector divided by a
scalar — sum(sum_over_time(m[5m])) / 300. The aggregate wrapper already
synthesises TimeUnix (wrapAggregateForSample), so this form worked before the
fix; pinned alongside the bare-range case so both binop-over-range shapes stay
covered. inner sum = 300 over the 5m window; / 300 = 1.
