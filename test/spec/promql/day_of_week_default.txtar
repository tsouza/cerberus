# `day_of_week()` — the zero-arg form. PromQL spec:
# `day_of_week()` ≡ `day_of_week(vector(time()))`. cerberus lowers
# it to a OneRow source. CH's `toDayOfWeek` returns 1-7 (Mon=1..Sun=7);
# PromQL `day_of_week` returns 0-6 (Sun=0..Sat=6) — `toDayOfWeek(d) % 7`
# bridges the gap.
#
# The result is wrapped in `toFloat64(...)`: `toDayOfWeek` returns
# UInt8, and the cursor decodes into `*float64`. Without the wrap
# the clickhouse-go/v2 driver errors with
# `converting UInt8 to *float64 is unsupported`. With the wrap CH
# projects the column as Float64 on the wire.

-- query.promql --
day_of_week()
-- seed --
CREATE TABLE otel_metrics_gauge (
    MetricName String,
    Attributes Map(String, String),
    TimeUnix DateTime64(9),
    Value Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
-- expected_rows --
[
  ["", {}, "2026-01-01T00:00:01Z", 4]
]
-- args --
[0] string = ""
[1] string = "Map(String,String)"
[2] int64 = 9
[3] int64 = 7
-- chplan --
Project ["" AS MetricName, CAST(map(), "Map(String,String)") AS Attributes, now64(9) AS TimeUnix, toFloat64((toDayOfWeek(now()) % 7)) AS Value]
  OneRow
-- sql --
SELECT ? AS `MetricName`, CAST(map(), ?) AS `Attributes`, now64(?) AS `TimeUnix`, toFloat64(arrayMap((__mx, __my) -> arrayMap(__myabs -> arrayMap(__myexp -> if(isNaN(__mx) OR isNaN(__my) OR isInfinite(__mx) OR __myabs = 0, CAST(0 AS Float64) / 0, if(isInfinite(__myabs), __mx, if(__mx < 0, CAST(-1 AS Float64), CAST(1 AS Float64)) * arrayFold((__macc, __mi) -> if(__macc >= __myabs, __macc - exp2(if(__myabs * exp2(if(__macc = 0, CAST(0 AS Float64), floor(log2(__macc))) + 1 - __myexp) > __macc, -1, 0) + if(__macc = 0, CAST(0 AS Float64), floor(log2(__macc))) + 1 - __myexp) * __myabs, __macc), CAST(range(64) AS Array(UInt8)), CAST(abs(__mx) AS Float64)))), [if(__myabs = 0, CAST(0 AS Float64), floor(log2(__myabs)) + 1)])[1], [abs(__my)])[1], [CAST(toDayOfWeek(now()) AS Float64)], [CAST(? AS Float64)])[1]) AS `Value` FROM (SELECT 1)
