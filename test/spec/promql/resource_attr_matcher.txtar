# rc.5 (task #123) — a `{k8s_namespace_name="prod"}` matcher must filter on
# the OTel ResourceAttributes map (candidate chain reverses the sanitized
# Prom label `k8s_namespace_name` -> dotted OTel key `k8s.namespace.name`),
# with Attributes winning on collision.
#
# BRANCH 4 emits coalesce(nullIf(Attributes[cands], ''),
# nullIf(ResourceAttributes[cands], ''), '') so the row whose namespace
# lives only in ResourceAttributes matches, the unrelated namespace is
# excluded, and the trailing '' floor keeps the LHS total (never NULL).

-- query.promql --
http_requests_total{k8s_namespace_name="prod"}
-- seed --
CREATE TABLE otel_metrics_sum (
    MetricName String,
    Attributes Map(String, String),
    ResourceAttributes Map(String, String),
    TimeUnix DateTime64(9),
    Value Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
INSERT INTO otel_metrics_sum VALUES
    ('http_requests_total', map('route', '/api'),  map('k8s.namespace.name', 'prod'),    toDateTime64('2026-01-01 00:00:00', 9), 5.0),
    ('http_requests_total', map('route', '/admin'), map('k8s.namespace.name', 'staging'), toDateTime64('2026-01-01 00:00:00', 9), 9.0);
-- expected_rows --
[
  ["http_requests_total", {"route": "/api", "k8s_namespace_name": "prod"}, "2026-01-01T00:00:00Z", 5.0]
]
