]
-- chplan --
Project ["" AS MetricName, Attributes AS Attributes, now64(9) AS TimeUnix, Value AS Value]
  HistogramQuantile phi=0 groupBy=[Attributes AS Attributes]
    Filter predicate=(MetricName IN ("http_server_request_duration", "http.server.request.duration", "http.server.request_duration", "http.server_request.duration", "http.server_request_duration", "http_server.request.duration", "http_server.request_duration", "http_server_request.duration"))
      Scan(otel_metrics_histogram)
