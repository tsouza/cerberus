# Native timeSeriesResampleToGridWithStaleness lowering WITH an `offset`
# modifier — the regression pin for the grid_ts anchor-axis bug (#1094).
#
# Offset must shift only the aggregate's MEMBERSHIP window (the start/end fed to
# timeSeriesResampleToGridWithStaleness), NOT the emitted anchor timestamps. The
# `timeSeriesRange` anchor axis (surfaced as the TimeUnix column) therefore
# renders the UNSHIFTED query grid [Start, End], while the aggregate's bounds are
# shifted left by the offset. A regression that fed the shifted bounds to
# timeSeriesRange would slide every emitted timestamp back by the offset (the
# forced-route prometheus-compat diff that surfaced this).
#
# Concretely, with `up offset 1m`, step 1m, grid [00:00, 00:05] and samples at
# 00:00:30 (v=1) and 00:02:30 (v=7), each anchor t carries the latest sample at
# or before (t - 1m): anchors 00:00/00:01 evaluate before the first sample and
# drop, and the surviving rows are stamped with the QUERY-grid anchor (00:02,
# 00:03, 00:04, 00:05) — never the offset-shifted (00:01..00:04). Samples sit at
# :30, away from every anchor-lookback left edge, so the chDB 25.8 closed-window
# quirk (fixed Prometheus-side at 25.9, the native auto floor) does not bite this
# value selection.
-- query.promql --
up offset 1m
-- range_step --
1m
-- experimental_ts_grid_resample --
on
-- seed --
CREATE TABLE otel_metrics_gauge (
    MetricName String,
    Attributes Map(String, String),
    ResourceAttributes Map(String, String) DEFAULT map(),
    TimeUnix DateTime64(9),
    Value Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
INSERT INTO otel_metrics_gauge (MetricName, Attributes, TimeUnix, Value) VALUES
    ('up', map('job', 'api'), toDateTime64('2026-01-01 00:00:30', 9), 1.0),
    ('up', map('job', 'api'), toDateTime64('2026-01-01 00:02:30', 9), 7.0);
-- args --
[0] string = "service.name"
[1] string = "service_name"
[2] string = "service.name"
[3] string = "service_name"
[4] string = "up"
-- expected_rows --
[
  ["up", {"job": "api"}, "2026-01-01T00:02:00Z", 1],
  ["up", {"job": "api"}, "2026-01-01T00:03:00Z", 1],
  ["up", {"job": "api"}, "2026-01-01T00:04:00Z", 7],
  ["up", {"job": "api"}, "2026-01-01T00:05:00Z", 7]
]
-- chplan --
RangeWindowResample step=1m0s lookback=5m0s offset=1m0s ts=TimeUnix value=Value start=2026-01-01T00:00:00Z end=2026-01-01T00:05:00Z
  Project [MetricName AS MetricName, mapUpdate(mapFromArrays(arrayMap(k -> replaceRegexpAll(k, "[^a-zA-Z0-9_]", "_"), mapKeys(mapFilter((k, v) -> (k NOT IN ("service.name", "service_name")), ResourceAttributes))), mapValues(mapFilter((k, v) -> (k NOT IN ("service.name", "service_name")), ResourceAttributes))), mapFromArrays(arrayMap(k -> replaceRegexpAll(k, "[^a-zA-Z0-9_]", "_"), mapKeys(Attributes)), mapValues(Attributes))) AS Attributes, TimeUnix AS TimeUnix, Value AS Value]
    Filter predicate=(MetricName = "up")
      Scan(merge(otel_metrics_gauge|otel_metrics_sum))
-- sql --
SELECT `MetricName`, `Attributes`, `anchor_ts` AS `TimeUnix`, toFloat64(assumeNotNull(`grid_val`)) AS `Value` FROM (SELECT `MetricName`, `Attributes`, timeSeriesResampleToGridWithStaleness((toDateTime64('2026-01-01 00:00:00.000000000', 9) - toIntervalNanosecond(60000000000)), (toDateTime64('2026-01-01 00:05:00.000000000', 9) - toIntervalNanosecond(60000000000)), 60, 300)(`TimeUnix`, `Value`) AS `grid`, timeSeriesRange(toDateTime64('2026-01-01 00:00:00.000000000', 9), toDateTime64('2026-01-01 00:05:00.000000000', 9), 60) AS `grid_ts` FROM (SELECT `MetricName` AS `MetricName`, mapUpdate(mapFromArrays(arrayMap(k -> replaceRegexpAll(k, '[^a-zA-Z0-9_]', '_'), mapKeys(mapFilter((k, v) -> (k NOT IN (?, ?)), `ResourceAttributes`))), mapValues(mapFilter((k, v) -> (k NOT IN (?, ?)), `ResourceAttributes`))), mapFromArrays(arrayMap(k -> replaceRegexpAll(k, '[^a-zA-Z0-9_]', '_'), mapKeys(`Attributes`)), mapValues(`Attributes`))) AS `Attributes`, `TimeUnix` AS `TimeUnix`, `Value` AS `Value` FROM (SELECT * FROM merge(currentDatabase(), '^(otel_metrics_gauge|otel_metrics_sum)$') PREWHERE (`MetricName` = ?))) WHERE `TimeUnix` > (toDateTime64('2026-01-01 00:00:00.000000000', 9) - toIntervalNanosecond(60000000000)) - toIntervalNanosecond(300000000000) AND `TimeUnix` <= (toDateTime64('2026-01-01 00:05:00.000000000', 9) - toIntervalNanosecond(60000000000)) GROUP BY `MetricName`, `Attributes`) ARRAY JOIN `grid` AS `grid_val`, `grid_ts` AS `anchor_ts` WHERE `grid_val` IS NOT NULL
