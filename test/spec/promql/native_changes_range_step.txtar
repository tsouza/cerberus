# Experimental: the ClickHouse-native timeSeriesChangesToGrid lowering for
# `sum by (X) (changes(metric[range]))` in range mode (Step > 0). This is the
# always-on SQL-shape coverage floor for the `ts_grid_changes` feature: the
# `experimental_ts_grid_changes` section opts the fixture into a
# RangeLowerers.Changes = NativeChangesLowerer, so the lowering emits a
# chplan.RangeWindowNative (Func=changes -> the timeSeriesChangesToGrid
# parametric aggregate + parallel timeSeriesRange axis + ARRAY JOIN +
# IS NOT NULL filter) instead of the arrayPopBack/arrayPopFront `c != p`
# fan-out. The wrapping outer-sum Aggregate is byte-identical to the fan-out;
# only the windowed-count subquery differs.
#
# VERSION FLOOR 25.9 (NOT 25.6). timeSeriesChangesToGrid shipped in PR #86010
# (ClickHouse 25.9), a full quarter after the rate/resample family — empirically
# confirmed ABSENT on the 25.8 chDB substrate. The chdb-tagged dual-emit parity
# test (range_window_changes_chdb_test.go) therefore feature-detects via
# system.functions and FALLS BACK to fan-out-only validation on a sub-25.9
# substrate: native==fan-out parity is VERSION-GATED, proven on a >= 25.9 server,
# not auto-proven on the current substrate. This SQL-shape golden still pins the
# emit unconditionally.
#
# changes() is a value-change COUNT over the window: each adjacent pair
# (prev, curr) with curr != prev contributes 1. Native timeSeriesChangesToGrid
# needs >= 1 sample/window (a single-sample window is a 0 count, not absent),
# mirroring the fan-out's `length(window_vals) >= 1` guard.

-- query.promql --
sum by(host) (changes(load_state[5m]))
-- range_step --
30s
-- experimental_ts_grid_changes --
-- seed --
CREATE TABLE otel_metrics_gauge (
    MetricName String,
    Attributes Map(String, String),
    TimeUnix DateTime64(9),
    Value Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
INSERT INTO otel_metrics_gauge VALUES
    ('load_state', map('host', 'a'), toDateTime64('2026-01-01 00:00:00', 9), 0.0),
    ('load_state', map('host', 'a'), toDateTime64('2026-01-01 00:01:00', 9), 1.0),
    ('load_state', map('host', 'a'), toDateTime64('2026-01-01 00:02:00', 9), 1.0),
    ('load_state', map('host', 'a'), toDateTime64('2026-01-01 00:03:00', 9), 0.0),
    ('load_state', map('host', 'a'), toDateTime64('2026-01-01 00:04:00', 9), 1.0),
    ('load_state', map('host', 'a'), toDateTime64('2026-01-01 00:05:00', 9), 1.0),
    ('load_state', map('host', 'b'), toDateTime64('2026-01-01 00:00:00', 9), 5.0),
    ('load_state', map('host', 'b'), toDateTime64('2026-01-01 00:01:00', 9), 5.0),
    ('load_state', map('host', 'b'), toDateTime64('2026-01-01 00:02:00', 9), 7.0),
    ('load_state', map('host', 'b'), toDateTime64('2026-01-01 00:03:00', 9), 7.0),
    ('load_state', map('host', 'b'), toDateTime64('2026-01-01 00:04:00', 9), 9.0),
    ('load_state', map('host', 'b'), toDateTime64('2026-01-01 00:05:00', 9), 2.0);
-- args --
[0] string = ""
[1] string = "host"
[2] string = "host"
[3] string = "service.name"
[4] string = "service_name"
[5] string = "service.name"
[6] string = "service_name"
[7] string = "load_state"
[8] string = "load.state"
[9] string = "load/state"
[10] string = "host"
-- chplan --
Project ["" AS MetricName, mapWithoutEmpty(map("host", gkey_0)) AS Attributes, bucket_ts AS TimeUnix, Value AS Value]
  Aggregate groupBy=[Attributes["host"] AS gkey_0, TimeUnix AS bucket_ts] funcs=[sum(Value) AS Value]
    RangeWindowNative func=changes range=5m0s step=30s ts=TimeUnix value=Value groupBy=[Attributes] start=2026-01-01T00:00:00Z end=2026-01-01T00:05:00Z
      Project [MetricName AS MetricName, mapUpdate(mapFromArrays(arrayMap(k -> replaceRegexpAll(k, "[^a-zA-Z0-9_]", "_"), mapKeys(mapFilter((k, v) -> (k NOT IN ("service.name", "service_name")), ResourceAttributes))), mapValues(mapFilter((k, v) -> (k NOT IN ("service.name", "service_name")), ResourceAttributes))), mapFromArrays(arrayMap(k -> replaceRegexpAll(k, "[^a-zA-Z0-9_]", "_"), mapKeys(Attributes)), mapValues(Attributes))) AS Attributes, TimeUnix AS TimeUnix, Value AS Value]
        Filter predicate=(MetricName IN ("load_state", "load.state", "load/state"))
          Scan(merge(otel_metrics_gauge|otel_metrics_sum))
-- sql --
SELECT ? AS `MetricName`, mapFilter((k, v) -> v != '', map(?, `gkey_0`)) AS `Attributes`, `bucket_ts` AS `TimeUnix`, `Value` AS `Value` FROM (SELECT `Attributes`[?] AS `gkey_0`, `TimeUnix` AS `bucket_ts`, sum(`Value`) AS `Value` FROM (SELECT `Attributes`, `anchor_ts`, `anchor_ts` AS `TimeUnix`, toFloat64(assumeNotNull(`grid_val`)) AS `Value` FROM (SELECT `Attributes`, timeSeriesChangesToGrid(toDateTime64('2026-01-01 00:00:00.000000000', 9), toDateTime64('2026-01-01 00:05:00.000000000', 9), 30, 300)(`TimeUnix`, `Value`) AS `grid`, timeSeriesRange(toDateTime64('2026-01-01 00:00:00.000000000', 9), toDateTime64('2026-01-01 00:05:00.000000000', 9), 30) AS `grid_ts` FROM (SELECT `MetricName` AS `MetricName`, mapUpdate(mapFromArrays(arrayMap(k -> replaceRegexpAll(k, '[^a-zA-Z0-9_]', '_'), mapKeys(mapFilter((k, v) -> (k NOT IN (?, ?)), `ResourceAttributes`))), mapValues(mapFilter((k, v) -> (k NOT IN (?, ?)), `ResourceAttributes`))), mapFromArrays(arrayMap(k -> replaceRegexpAll(k, '[^a-zA-Z0-9_]', '_'), mapKeys(`Attributes`)), mapValues(`Attributes`))) AS `Attributes`, `TimeUnix` AS `TimeUnix`, `Value` AS `Value` FROM (SELECT * FROM merge(currentDatabase(), '^(otel_metrics_gauge|otel_metrics_sum)$') WHERE (`MetricName` IN (?, ?, ?)))) WHERE `TimeUnix` > toDateTime64('2026-01-01 00:00:00.000000000', 9) - toIntervalNanosecond(300000000000) AND `TimeUnix` <= toDateTime64('2026-01-01 00:05:00.000000000', 9) GROUP BY `Attributes`) ARRAY JOIN `grid` AS `grid_val`, `grid_ts` AS `anchor_ts` WHERE `grid_val` IS NOT NULL) GROUP BY `Attributes`[?], `TimeUnix`)
