# Range-mode `rate(metric[5m] offset 2m)`: the `offset` shifts only WHICH
# samples each anchor reads, NOT the timestamp the result is reported at. The
# output anchors stay on the UNSHIFTED request grid a_i = End - i*step (what
# Prometheus reports and what cerberus's oracle stamps); the offset shifts only
# the membership window, which lives in (a_i - 2m - 5m, a_i - 2m]. The emitter
# keeps its internal anchor_ts offset-shifted for the window/rate math but adds
# the offset back on the emitted TimeUnix (gridAnchorFrag), so a range-offset
# query reports on the same grid a bare rate() does. The inner-scan pushdown
# still shifts WITH the offset: `TimeUnix > (Start - 2m) - 5m AND TimeUnix <=
# (End - 2m)`. Seed extends back before rangeStart so the shifted windows stay
# populated; the expected_rows pin the unshifted output timestamps.

-- query.promql --
sum by(cerberus_ql) (rate(cerberus_queries_total[5m] offset 2m))
-- range_step --
1m
-- seed --
CREATE TABLE otel_metrics_sum (
    MetricName String,
    Attributes Map(String, String),
    TimeUnix DateTime64(9),
    Value Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
