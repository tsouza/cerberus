-- query.promql --
histogram_quantile(0.999, http_server_duration_exp_hist)
-- args --
[0] string = ""
[1] int64 = 9
[2] string = "http_server_duration_exp_hist"
-- sql --
SELECT ? AS `MetricName`, `Attributes` AS `Attributes`, now64(?) AS `TimeUnix`, `Value` AS `Value` FROM (SELECT `Attributes` AS `Attributes`, if(arrayCumSum(arrayConcat([`ZeroCount`], `PositiveBucketCounts`))[length(arrayCumSum(arrayConcat([`ZeroCount`], `PositiveBucketCounts`)))] = 0, nan, if(0.999 <= 0, 0.0, if(0.999 >= 1, pow(pow(2, pow(2, -`Scale`)), `PositiveOffset` + length(`PositiveBucketCounts`)), if(arrayFirstIndex(c -> c >= (0.999 * arrayCumSum(arrayConcat([`ZeroCount`], `PositiveBucketCounts`))[length(arrayCumSum(arrayConcat([`ZeroCount`], `PositiveBucketCounts`)))]), arrayCumSum(arrayConcat([`ZeroCount`], `PositiveBucketCounts`))) = 1, `ZeroThreshold`, pow(pow(2, pow(2, -`Scale`)), `PositiveOffset` + (arrayFirstIndex(c -> c >= (0.999 * arrayCumSum(arrayConcat([`ZeroCount`], `PositiveBucketCounts`))[length(arrayCumSum(arrayConcat([`ZeroCount`], `PositiveBucketCounts`)))]), arrayCumSum(arrayConcat([`ZeroCount`], `PositiveBucketCounts`))) - 2) + ((0.999 * arrayCumSum(arrayConcat([`ZeroCount`], `PositiveBucketCounts`))[length(arrayCumSum(arrayConcat([`ZeroCount`], `PositiveBucketCounts`)))]) - arrayCumSum(arrayConcat([`ZeroCount`], `PositiveBucketCounts`))[arrayFirstIndex(c -> c >= (0.999 * arrayCumSum(arrayConcat([`ZeroCount`], `PositiveBucketCounts`))[length(arrayCumSum(arrayConcat([`ZeroCount`], `PositiveBucketCounts`)))]), arrayCumSum(arrayConcat([`ZeroCount`], `PositiveBucketCounts`))) - 1]) / (arrayCumSum(arrayConcat([`ZeroCount`], `PositiveBucketCounts`))[arrayFirstIndex(c -> c >= (0.999 * arrayCumSum(arrayConcat([`ZeroCount`], `PositiveBucketCounts`))[length(arrayCumSum(arrayConcat([`ZeroCount`], `PositiveBucketCounts`)))]), arrayCumSum(arrayConcat([`ZeroCount`], `PositiveBucketCounts`)))] - arrayCumSum(arrayConcat([`ZeroCount`], `PositiveBucketCounts`))[arrayFirstIndex(c -> c >= (0.999 * arrayCumSum(arrayConcat([`ZeroCount`], `PositiveBucketCounts`))[length(arrayCumSum(arrayConcat([`ZeroCount`], `PositiveBucketCounts`)))]), arrayCumSum(arrayConcat([`ZeroCount`], `PositiveBucketCounts`))) - 1])))))) AS `Value` FROM (SELECT * FROM `otel_metrics_exp_histogram` WHERE (`MetricName` = ?)))
-- chplan --
Project ["" AS MetricName, Attributes AS Attributes, now64(9) AS TimeUnix, Value AS Value]
  HistogramQuantileNative phi=0.999 groupBy=[Attributes AS Attributes]
    Filter predicate=(MetricName = "http_server_duration_exp_hist")
      Scan(otel_metrics_exp_histogram)
