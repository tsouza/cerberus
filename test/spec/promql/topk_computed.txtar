-- query.promql --
topk(scalar(metric_k), up)
-- seed --
CREATE TABLE otel_metrics_gauge (
    MetricName String,
    Attributes Map(String, String),
    TimeUnix DateTime64(9),
    Value Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
INSERT INTO otel_metrics_gauge VALUES
    ('up', map('instance', 'a'), toDateTime64('2026-01-01 00:00:00', 9), 0.4),
    ('up', map('instance', 'b'), toDateTime64('2026-01-01 00:00:00', 9), 0.2),
    ('up', map('instance', 'c'), toDateTime64('2026-01-01 00:00:00', 9), 0.9),
    ('up', map('instance', 'd'), toDateTime64('2026-01-01 00:00:00', 9), 0.7),
    ('metric_k', map(), toDateTime64('2026-01-01 00:00:00', 9), 2.0);
-- expected_rows --
[
  ["up", {"instance": "c"}, "2026-01-01T00:00:00Z", 0.9],
  ["up", {"instance": "d"}, "2026-01-01T00:00:00Z", 0.7]
]
-- args --
[0] string = "up"
[1] string = "2026-01-01 00:00:01.000000000"
[2] int64 = 9
[3] string = "2026-01-01 00:00:01.000000000"
[4] int64 = 9
[5] int64 = 300000000000
[6] string = "metric_k"
[7] string = "2026-01-01 00:00:01.000000000"
[8] int64 = 9
[9] string = "2026-01-01 00:00:01.000000000"
[10] int64 = 9
[11] int64 = 300000000000
-- chplan --
TopK k=<expr> sort=Value DESC columns=[MetricName, Attributes, TimeUnix, Value]
  Project [MetricName AS MetricName, Attributes AS Attributes, lwr_ts AS TimeUnix, lwr_value AS Value]
    Aggregate groupBy=[MetricName AS MetricName, Attributes AS Attributes] funcs=[max(TimeUnix) AS lwr_ts, argMax(Value, TimeUnix) AS lwr_value]
      Filter predicate=(((MetricName = "up") AND (TimeUnix <= toDateTime64("2026-01-01 00:00:01.000000000", 9))) AND (TimeUnix > (toDateTime64("2026-01-01 00:00:01.000000000", 9) - toIntervalNanosecond(300000000000))))
        Scan(otel_metrics_gauge)
  KExpr:
    Project [MetricName AS MetricName, Attributes AS Attributes, lwr_ts AS TimeUnix, lwr_value AS Value]
      Aggregate groupBy=[MetricName AS MetricName, Attributes AS Attributes] funcs=[max(TimeUnix) AS lwr_ts, argMax(Value, TimeUnix) AS lwr_value]
        Filter predicate=(((MetricName = "metric_k") AND (TimeUnix <= toDateTime64("2026-01-01 00:00:01.000000000", 9))) AND (TimeUnix > (toDateTime64("2026-01-01 00:00:01.000000000", 9) - toIntervalNanosecond(300000000000))))
          Scan(otel_metrics_gauge)
-- sql --
SELECT `MetricName`, `Attributes`, `TimeUnix`, `Value` FROM (SELECT *, row_number() OVER (ORDER BY `Value` DESC) AS `_rn` FROM (SELECT `MetricName` AS `MetricName`, `Attributes` AS `Attributes`, `lwr_ts` AS `TimeUnix`, `lwr_value` AS `Value` FROM (SELECT `MetricName` AS `MetricName`, `Attributes` AS `Attributes`, max(`TimeUnix`) AS `lwr_ts`, argMax(`Value`, `TimeUnix`) AS `lwr_value` FROM (SELECT * FROM `otel_metrics_gauge` PREWHERE (`MetricName` = ?) WHERE (`TimeUnix` <= toDateTime64(?, ?)) AND (`TimeUnix` > (toDateTime64(?, ?) - toIntervalNanosecond(?)))) GROUP BY `MetricName`, `Attributes`))) WHERE `_rn` <= (SELECT toUInt64(`Value`) FROM (SELECT `MetricName` AS `MetricName`, `Attributes` AS `Attributes`, `lwr_ts` AS `TimeUnix`, `lwr_value` AS `Value` FROM (SELECT `MetricName` AS `MetricName`, `Attributes` AS `Attributes`, max(`TimeUnix`) AS `lwr_ts`, argMax(`Value`, `TimeUnix`) AS `lwr_value` FROM (SELECT * FROM `otel_metrics_gauge` PREWHERE (`MetricName` = ?) WHERE (`TimeUnix` <= toDateTime64(?, ?)) AND (`TimeUnix` > (toDateTime64(?, ?) - toIntervalNanosecond(?)))) GROUP BY `MetricName`, `Attributes`)) LIMIT 1)
