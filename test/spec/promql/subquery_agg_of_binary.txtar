-- query.promql --
max_over_time(sum(up + up)[5m:1m])
-- seed --
CREATE TABLE otel_metrics_gauge (
    MetricName String,
    Attributes Map(String, String),
    TimeUnix DateTime64(9),
    Value Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
INSERT INTO otel_metrics_gauge VALUES
    ('up', map('job', 'api'), toDateTime64('2025-12-31 23:56:00', 9), 10),
    ('up', map('job', 'api'), toDateTime64('2025-12-31 23:58:00', 9), 20),
    ('up', map('job', 'api'), toDateTime64('2026-01-01 00:00:00', 9), 30);
