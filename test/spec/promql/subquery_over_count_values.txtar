-- query.promql --
max_over_time(count_values("v", up)[5m:1m])
-- seed --
CREATE TABLE otel_metrics_gauge (
    MetricName String,
    Attributes Map(String, String),
    TimeUnix DateTime64(9),
    Value Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
INSERT INTO otel_metrics_gauge VALUES
    ('up', map('job', 'api'), toDateTime64('2025-12-31 23:58:30', 9), 1.0),
    ('up', map('job', 'api'), toDateTime64('2025-12-31 23:59:30', 9), 1.0),
    ('up', map('job', 'api'), toDateTime64('2026-01-01 00:00:00', 9), 1.0),
    ('up', map('job', 'web'), toDateTime64('2025-12-31 23:58:30', 9), 0.0),
    ('up', map('job', 'web'), toDateTime64('2025-12-31 23:59:30', 9), 0.0),
    ('up', map('job', 'web'), toDateTime64('2026-01-01 00:00:00', 9), 0.0);
-- expected_rows --
[
  [{"v": "0"}, 1.0],
  [{"v": "1"}, 1.0]
]
-- args --
[0] string = "v"
[1] string = "up"
-- chplan --
RangeWindow func=max_over_time range=5m0s step=0s ts=anchor_ts value=Value groupBy=[Attributes]
  Project [mapWithoutEmpty(map("v", cv_val)) AS Attributes, anchor_ts AS anchor_ts, toFloat64(cv_count) AS Value]
    Aggregate groupBy=[toString(Value) AS cv_val, anchor_ts AS anchor_ts] funcs=[count() AS cv_count]
      RangeWindow func= range=1m0s step=1m0s outerRange=5m0s identity=true ts=TimeUnix value=Value groupBy=[Attributes]
        Filter predicate=(MetricName = "up")
          Scan(merge(otel_metrics_gauge|otel_metrics_sum))
-- sql --
SELECT `Attributes`, max(`Value`) AS `Value` FROM (SELECT mapFilter((k, v) -> v != '', map(?, `cv_val`)) AS `Attributes`, `anchor_ts` AS `anchor_ts`, toFloat64(`cv_count`) AS `Value` FROM (SELECT toString(`Value`) AS `cv_val`, `anchor_ts` AS `anchor_ts`, toFloat64(count()) AS `cv_count` FROM (SELECT `Attributes`, `anchor_ts`, anchor_ts AS `TimeUnix`, if(length(window_vals) > 0, window_vals[length(window_vals)], nan) AS `Value` FROM (SELECT `Attributes`, `anchor_ts`, arrayMap(p -> tupleElement(p, 2), window_pairs) AS `window_vals`, arraySum(arrayMap((p, c) -> if(c < p, c, c - p), arrayPopBack(arrayMap(x -> tupleElement(x, 2), window_pairs)), arrayPopFront(arrayMap(x -> tupleElement(x, 2), window_pairs)))) AS `counter_delta` FROM (SELECT `Attributes`, `anchor_ts`, arraySort(groupArray((`TimeUnix`, `Value`))) AS `window_pairs` FROM (SELECT `Attributes`, `TimeUnix`, `Value`, arrayJoin(arrayMap(i -> now64(9) - toIntervalNanosecond(i * 60000000000), range(greatest(0, intDiv(dateDiff('nanosecond', `TimeUnix`, now64(9)) - 60000000000, toInt64(60000000000)) - (modulo(dateDiff('nanosecond', `TimeUnix`, now64(9)) - 60000000000, toInt64(60000000000)) < 0) + 1), least(6, intDiv(dateDiff('nanosecond', `TimeUnix`, now64(9)), toInt64(60000000000)) - (modulo(dateDiff('nanosecond', `TimeUnix`, now64(9)), toInt64(60000000000)) < 0) + 1)))) AS `anchor_ts` FROM (SELECT * FROM merge(currentDatabase(), '^(otel_metrics_gauge|otel_metrics_sum)$') WHERE (`MetricName` = ?))) GROUP BY `Attributes`, `anchor_ts`)) WHERE length(`window_vals`) >= 1) GROUP BY toString(`Value`), `anchor_ts`)) WHERE `anchor_ts` > now64(9) - toIntervalNanosecond(300000000000) AND `anchor_ts` <= now64(9) GROUP BY `Attributes`
