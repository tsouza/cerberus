-- query.promql --
predict_linear(http_requests_total[5m], scalar(threshold) * 120)
-- seed --
CREATE TABLE otel_metrics_gauge (
    MetricName String,
    Attributes Map(String, String),
    TimeUnix DateTime64(9),
    Value Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
CREATE TABLE otel_metrics_sum (
    MetricName String,
    Attributes Map(String, String),
    TimeUnix DateTime64(9),
    Value Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
INSERT INTO otel_metrics_sum VALUES
    ('http_requests_total', map('job', 'api'), toDateTime64('2025-12-31 23:56:00', 9), 100),
    ('http_requests_total', map('job', 'api'), toDateTime64('2025-12-31 23:58:00', 9), 220),
    ('http_requests_total', map('job', 'api'), toDateTime64('2026-01-01 00:00:00', 9), 340);
INSERT INTO otel_metrics_gauge VALUES
    ('threshold', map('env', 'prod'), toDateTime64('2026-01-01 00:00:00', 9), 0.5);
