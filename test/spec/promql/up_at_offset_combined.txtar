-- query.promql --
up @ 1640995200 offset 5m
-- sql --
SELECT * FROM (SELECT * FROM `otel_metrics_gauge`) WHERE ((`MetricName` = ?) AND (`TimeUnix` <= (toDateTime64(?, ?) - toIntervalNanosecond(?))))
