-- query.promql --
max_over_time(avg_over_time(up[5m])[1h:5m])
-- args --
[0] string = "up"
-- sql --
SELECT `Attributes`, if(length(window_vals) > 0, arrayMax(window_vals), nan) AS `Value` FROM (SELECT `Attributes`, arrayMap(p -> tupleElement(p, 2), window_pairs) AS `window_vals`, arraySum(arrayMap((p, c) -> if(c < p, c, c - p), arrayPopBack(arrayMap(x -> tupleElement(x, 2), window_pairs)), arrayPopFront(arrayMap(x -> tupleElement(x, 2), window_pairs)))) AS `counter_delta` FROM (SELECT `Attributes`, arrayFilter(p -> tupleElement(p, 1) > now64(9) - toIntervalNanosecond(3600000000000) AND tupleElement(p, 1) <= now64(9), series_array) AS `window_pairs` FROM (SELECT `Attributes`, arraySort(groupArray((`anchor_ts`, `Value`))) AS `series_array` FROM (SELECT `Attributes`, `anchor_ts`, anchor_ts AS `TimeUnix`, if(length(window_vals) > 0, arrayAvg(window_vals), nan) AS `Value` FROM (SELECT `Attributes`, `anchor_ts`, arrayMap(p -> tupleElement(p, 2), window_pairs) AS `window_vals`, arraySum(arrayMap((p, c) -> if(c < p, c, c - p), arrayPopBack(arrayMap(x -> tupleElement(x, 2), window_pairs)), arrayPopFront(arrayMap(x -> tupleElement(x, 2), window_pairs)))) AS `counter_delta` FROM (SELECT `Attributes`, `anchor_ts`, arraySort(groupArray((`TimeUnix`, `Value`))) AS `window_pairs` FROM (SELECT `Attributes`, `TimeUnix`, `Value`, arrayJoin(arrayMap(i -> now64(9) - toIntervalNanosecond(i * 300000000000), range(greatest(0, intDiv(dateDiff('nanosecond', `TimeUnix`, now64(9)) - 300000000000, toInt64(300000000000)) - (modulo(dateDiff('nanosecond', `TimeUnix`, now64(9)) - 300000000000, toInt64(300000000000)) < 0) + 1), least(13, intDiv(dateDiff('nanosecond', `TimeUnix`, now64(9)), toInt64(300000000000)) - (modulo(dateDiff('nanosecond', `TimeUnix`, now64(9)), toInt64(300000000000)) < 0) + 1)))) AS `anchor_ts` FROM (SELECT * FROM merge(currentDatabase(), '^(otel_metrics_gauge|otel_metrics_sum)$') WHERE (`MetricName` = ?))) GROUP BY `Attributes`, `anchor_ts`)) WHERE length(`window_vals`) >= 1) GROUP BY `Attributes`))) WHERE length(`window_vals`) >= 1
-- chplan --
RangeWindow func=max_over_time range=1h0m0s step=0s ts=anchor_ts value=Value groupBy=[Attributes]
  RangeWindow func=avg_over_time range=5m0s step=5m0s outerRange=1h0m0s ts=TimeUnix value=Value groupBy=[Attributes]
    Filter predicate=(MetricName = "up")
      Scan(merge(otel_metrics_gauge|otel_metrics_sum))
-- seed --
CREATE TABLE otel_metrics_gauge (
    MetricName String,
    Attributes Map(String, String),
    TimeUnix DateTime64(9),
    Value Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
INSERT INTO otel_metrics_gauge VALUES
    ('up', map('instance', 'a'), toDateTime64('2026-01-01 00:00:00', 9), 42.0);
-- expected_rows --
[
  [{"instance": "a"}, 42]
]
