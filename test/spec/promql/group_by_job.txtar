-- query.promql --
group by (job) (up)
-- sql --
SELECT ? AS `MetricName`, map(?, `gkey_0`) AS `Attributes`, now64(?) AS `TimeUnix`, `Value` AS `Value` FROM (SELECT `Attributes`[?] AS `gkey_0`, any(?) AS `Value` FROM (SELECT * FROM `otel_metrics_gauge` WHERE (`MetricName` = ?)) GROUP BY `Attributes`[?])
-- args --
[0] string = ""
[1] string = "job"
[2] int64 = 9
[3] string = "job"
[4] int64 = 1
[5] string = "up"
[6] string = "job"
