-- seed --
CREATE TABLE otel_metrics_histogram (
    MetricName String,
    Attributes Map(String, String),
    TimeUnix DateTime64(9),
    Count UInt64,
    Sum Float64,
    BucketCounts Array(UInt64),
    ExplicitBounds Array(Float64)
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
CREATE TABLE otel_metrics_sum (
    MetricName String,
    Attributes Map(String, String),
    TimeUnix DateTime64(9),
    Value Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
INSERT INTO otel_metrics_sum VALUES
    ('system_cpu_logical_count', map('host', 'h1'), toDateTime64('2026-01-01 00:00:00', 9), 8.0);
-- expected_rows --
[
  ["system_cpu_logical_count", {"host": "h1"}, "2026-01-01T00:00:00Z", 8.0]
]
-- description --
Regression pin for PR #710's follow-up: the histogram-companion
suffix `_count` / `_sum` routing forced the scan to the histogram
table only, returning empty for OTel-hostmetrics counters that ship
under suffixed names in the sum table (`system_cpu_logical_count`,
`system_processes_count`, `system_filesystem_inodes_count`,
`system_processes_created_count`, …).

The fix: schema.Metrics.TablesFor returns `[Histogram, Sum]` for
`_count` / `_sum` suffixed names, and the lowering builds a
chplan.UnionAll of two per-arm Projects. Each arm bakes its own
scan-side MetricName filter — the histogram arm filters on the BARE
base name (`system_cpu_logical`, where the OTel-CH histogram
exporter stores Count / Sum on a single row), the sum arm filters
on the SUFFIXED name (`system_cpu_logical_count`, where the OTel
hostmetrics emitter stores the cumulative count). The histogram arm
projects `MetricName` as the suffixed literal so both arms produce
identically-shaped rows; the union is positional-column-safe.

The seed creates an empty histogram table alongside a populated sum
table so the chDB roundtrip exercises the sum-table arm of the
union — a regression that dropped this arm would return zero rows.
-- chplan --
Project [MetricName AS MetricName, Attributes AS Attributes, lwr_ts AS TimeUnix, lwr_value AS Value]
  Aggregate groupBy=[MetricName AS MetricName, Attributes AS Attributes] funcs=[max(TimeUnix) AS lwr_ts, argMax(Value, TimeUnix) AS lwr_value]
    Filter predicate=((TimeUnix <= toDateTime64("2026-01-01 00:00:01.000000000", 9)) AND (TimeUnix > (toDateTime64("2026-01-01 00:00:01.000000000", 9) - toIntervalNanosecond(300000000000))))
      UnionAll arms=3
        Project ["system_cpu_logical_count" AS MetricName, mapUpdate(mapFromArrays(arrayMap(k -> replaceRegexpAll(k, "[^a-zA-Z0-9_]", "_"), mapKeys(mapFilter((k, v) -> (k NOT IN ("service.name", "service_name")), ResourceAttributes))), mapValues(mapFilter((k, v) -> (k NOT IN ("service.name", "service_name")), ResourceAttributes))), mapFromArrays(arrayMap(k -> replaceRegexpAll(k, "[^a-zA-Z0-9_]", "_"), mapKeys(Attributes)), mapValues(Attributes))) AS Attributes, TimeUnix AS TimeUnix, toFloat64(Count) AS Value]
          Filter predicate=(MetricName IN ("system_cpu_logical", "system.cpu.logical", "system.cpu/logical", "system.cpu_logical", "system/cpu/logical", "system/cpu_logical", "system_cpu.logical"))
            Scan(otel_metrics_histogram)
        Project [MetricName AS MetricName, mapUpdate(mapFromArrays(arrayMap(k -> replaceRegexpAll(k, "[^a-zA-Z0-9_]", "_"), mapKeys(mapFilter((k, v) -> (k NOT IN ("service.name", "service_name")), ResourceAttributes))), mapValues(mapFilter((k, v) -> (k NOT IN ("service.name", "service_name")), ResourceAttributes))), mapFromArrays(arrayMap(k -> replaceRegexpAll(k, "[^a-zA-Z0-9_]", "_"), mapKeys(Attributes)), mapValues(Attributes))) AS Attributes, TimeUnix AS TimeUnix, Value AS Value]
          Filter predicate=(MetricName IN ("system_cpu_logical_count", "system.cpu.logical.count", "system.cpu.logical/count", "system.cpu.logical_count", "system.cpu/logical/count", "system.cpu/logical_count", "system.cpu_logical.count", "system.cpu_logical_count", "system/cpu/logical/count", "system/cpu/logical_count", "system/cpu_logical_count", "system_cpu.logical.count", "system_cpu.logical_count", "system_cpu_logical.count"))
            Scan(otel_metrics_sum)
        Project [MetricName AS MetricName, mapUpdate(mapFromArrays(arrayMap(k -> replaceRegexpAll(k, "[^a-zA-Z0-9_]", "_"), mapKeys(mapFilter((k, v) -> (k NOT IN ("service.name", "service_name")), ResourceAttributes))), mapValues(mapFilter((k, v) -> (k NOT IN ("service.name", "service_name")), ResourceAttributes))), mapFromArrays(arrayMap(k -> replaceRegexpAll(k, "[^a-zA-Z0-9_]", "_"), mapKeys(Attributes)), mapValues(Attributes))) AS Attributes, TimeUnix AS TimeUnix, Value AS Value]
          Filter predicate=(MetricName IN ("system_cpu_logical_count", "system.cpu.logical.count", "system.cpu.logical/count", "system.cpu.logical_count", "system.cpu/logical/count", "system.cpu/logical_count", "system.cpu_logical.count", "system.cpu_logical_count", "system/cpu/logical/count", "system/cpu/logical_count", "system/cpu_logical_count", "system_cpu.logical.count", "system_cpu.logical_count", "system_cpu_logical.count"))
            Scan(otel_metrics_gauge)
-- sql --
SELECT `MetricName` AS `MetricName`, `Attributes` AS `Attributes`, `lwr_ts` AS `TimeUnix`, `lwr_value` AS `Value` FROM (SELECT `MetricName` AS `MetricName`, `Attributes` AS `Attributes`, max(`TimeUnix`) AS `lwr_ts`, argMax(`Value`, `TimeUnix`) AS `lwr_value` FROM (SELECT * FROM ((SELECT ? AS `MetricName`, mapUpdate(mapFromArrays(arrayMap(k -> replaceRegexpAll(k, '[^a-zA-Z0-9_]', '_'), mapKeys(mapFilter((k, v) -> (k NOT IN (?, ?)), `ResourceAttributes`))), mapValues(mapFilter((k, v) -> (k NOT IN (?, ?)), `ResourceAttributes`))), mapFromArrays(arrayMap(k -> replaceRegexpAll(k, '[^a-zA-Z0-9_]', '_'), mapKeys(`Attributes`)), mapValues(`Attributes`))) AS `Attributes`, `TimeUnix` AS `TimeUnix`, toFloat64(`Count`) AS `Value` FROM (SELECT * FROM `otel_metrics_histogram` WHERE (`MetricName` IN (?, ?, ?, ?, ?, ?, ?)))) UNION ALL (SELECT `MetricName` AS `MetricName`, mapUpdate(mapFromArrays(arrayMap(k -> replaceRegexpAll(k, '[^a-zA-Z0-9_]', '_'), mapKeys(mapFilter((k, v) -> (k NOT IN (?, ?)), `ResourceAttributes`))), mapValues(mapFilter((k, v) -> (k NOT IN (?, ?)), `ResourceAttributes`))), mapFromArrays(arrayMap(k -> replaceRegexpAll(k, '[^a-zA-Z0-9_]', '_'), mapKeys(`Attributes`)), mapValues(`Attributes`))) AS `Attributes`, `TimeUnix` AS `TimeUnix`, `Value` AS `Value` FROM (SELECT * FROM `otel_metrics_sum` WHERE (`MetricName` IN (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)))) UNION ALL (SELECT `MetricName` AS `MetricName`, mapUpdate(mapFromArrays(arrayMap(k -> replaceRegexpAll(k, '[^a-zA-Z0-9_]', '_'), mapKeys(mapFilter((k, v) -> (k NOT IN (?, ?)), `ResourceAttributes`))), mapValues(mapFilter((k, v) -> (k NOT IN (?, ?)), `ResourceAttributes`))), mapFromArrays(arrayMap(k -> replaceRegexpAll(k, '[^a-zA-Z0-9_]', '_'), mapKeys(`Attributes`)), mapValues(`Attributes`))) AS `Attributes`, `TimeUnix` AS `TimeUnix`, `Value` AS `Value` FROM (SELECT * FROM `otel_metrics_gauge` WHERE (`MetricName` IN (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?))))) WHERE ((`TimeUnix` <= toDateTime64(?, ?)) AND (`TimeUnix` > (toDateTime64(?, ?) - toIntervalNanosecond(?))))) GROUP BY `MetricName`, `Attributes`)
