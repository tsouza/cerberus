  UnionAll arms=2
    Project ["http_server_request_duration_sum" AS MetricName, Attributes AS Attributes, TimeUnix AS TimeUnix, toFloat64(Sum) AS Value]
      Filter predicate=((((((((MetricName = "http_server_request_duration") OR (MetricName = "http.server.request.duration")) OR (MetricName = "http.server.request_duration")) OR (MetricName = "http.server_request.duration")) OR (MetricName = "http.server_request_duration")) OR (MetricName = "http_server.request.duration")) OR (MetricName = "http_server.request_duration")) OR (MetricName = "http_server_request.duration"))
