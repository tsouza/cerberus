-- chplan --
Project ["" AS MetricName, Attributes AS Attributes, now64(9) AS TimeUnix, Value AS Value]
  HistogramQuantile phi=scalarSubquery{Project [if((_cerb_scnt = 1), _cerb_sval, NaN) AS Value] ; Aggregate groupBy=[] funcs=[count() AS _cerb_scnt, any(Value) AS _cerb_sval] ; Project [MetricName AS MetricName, Attributes AS Attributes, lwr_ts AS TimeUnix, lwr_value AS Value] ; Aggregate groupBy=[MetricName AS MetricName, Attributes AS Attributes] funcs=[max(TimeUnix) AS lwr_ts, argMax(Value, TimeUnix) AS lwr_value] ; Filter predicate=(((MetricName = "threshold") AND (TimeUnix <= toDateTime64("2026-01-01 00:00:01.000000000", 9))) AND (TimeUnix > (toDateTime64("2026-01-01 00:00:01.000000000", 9) - toIntervalNanosecond(300000000000)))) ; Scan(merge(otel_metrics_gauge|otel_metrics_sum))} groupBy=[Attributes AS Attributes]
    Filter predicate=((((((((MetricName = "http_server_request_duration") OR (MetricName = "http.server.request.duration")) OR (MetricName = "http.server.request_duration")) OR (MetricName = "http.server_request.duration")) OR (MetricName = "http.server_request_duration")) OR (MetricName = "http_server.request.duration")) OR (MetricName = "http_server.request_duration")) OR (MetricName = "http_server_request.duration"))
      Scan(otel_metrics_histogram)
