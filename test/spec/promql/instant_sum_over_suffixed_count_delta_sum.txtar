-- query.promql --
sum(loadbalancing_googleapis_com_https_request_count)
-- seed --
CREATE TABLE otel_metrics_histogram (
    MetricName String, Attributes Map(String, String), ResourceAttributes Map(String, String),
    TimeUnix DateTime64(9), Count UInt64, Sum Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
CREATE TABLE otel_metrics_sum (
    MetricName String, Attributes Map(String, String), ResourceAttributes Map(String, String),
    TimeUnix DateTime64(9), Value Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
CREATE TABLE otel_metrics_gauge (
    MetricName String, Attributes Map(String, String), ResourceAttributes Map(String, String),
    TimeUnix DateTime64(9), Value Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
INSERT INTO otel_metrics_sum VALUES
    ('loadbalancing_googleapis_com_https_request_count', map('lb', 'a'), map(), toDateTime64('2026-01-01 00:00:00', 9), 100),
    ('loadbalancing_googleapis_com_https_request_count', map('lb', 'b'), map(), toDateTime64('2026-01-01 00:00:00', 9), 166);
-- expected_rows --
[
  ["", {}, "2026-01-01T00:00:01Z", 266]
]
-- description --
Regression (rc.8 Issue D): instant sum() over a _count-suffixed DELTA Sum metric
whose data lives in otel_metrics_sum (resolved via the rc.5 companion union). The
rc.7 report saw this return empty; investigation showed cerberus is correct — the
instant path applies the standard Prometheus 5m staleness lookback, and the value
resolves when a sample is in-window (the production empty was GCP Cloud Monitoring
ingestion lag pushing the latest delta point past 5m, matching reference Prom).
This pins the in-window behaviour: sum over the 2 series = 266.
