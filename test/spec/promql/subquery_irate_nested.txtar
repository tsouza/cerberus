-- query.promql --
max_over_time(irate(up[5m:1m])[10m:1m])
-- seed --
CREATE TABLE otel_metrics_gauge (
    MetricName String,
    Attributes Map(String, String),
    TimeUnix DateTime64(9),
    Value Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
INSERT INTO otel_metrics_gauge VALUES
    ('up', map('job', 'api'), toDateTime64('2025-12-31 23:56:00', 9), 10),
    ('up', map('job', 'api'), toDateTime64('2025-12-31 23:58:00', 9), 20),
    ('up', map('job', 'api'), toDateTime64('2026-01-01 00:00:00', 9), 30);
-- expected_rows --
[
  [{"job": "api"}, 0.08333333333333333]
]
-- args --
[0] string = "up"
-- chplan --
RangeWindow func=max_over_time range=10m0s step=0s ts=anchor_ts value=Value groupBy=[Attributes]
  RangeWindow func=irate range=5m0s step=1m0s outerRange=10m0s ts=anchor_ts value=Value groupBy=[Attributes]
    RangeWindow func= range=1m0s step=1m0s outerRange=15m0s identity=true ts=TimeUnix value=Value groupBy=[Attributes]
      Filter predicate=(MetricName = "up")
        Scan(merge(otel_metrics_gauge|otel_metrics_sum))
-- sql --
SELECT `Attributes`, max(`Value`) AS `Value` FROM (SELECT `Attributes`, `anchor_ts`, if(length(window_pairs) > 1 AND dateDiff('nanosecond', tupleElement(window_pairs[length(window_pairs) - 1], 1), tupleElement(window_pairs[length(window_pairs)], 1)) > 0, (if(tupleElement(window_pairs[length(window_pairs)], 2) < tupleElement(window_pairs[length(window_pairs) - 1], 2), tupleElement(window_pairs[length(window_pairs)], 2), tupleElement(window_pairs[length(window_pairs)], 2) - tupleElement(window_pairs[length(window_pairs) - 1], 2))) / ((dateDiff('nanosecond', tupleElement(window_pairs[length(window_pairs) - 1], 1), tupleElement(window_pairs[length(window_pairs)], 1))) / 1e9), nan) AS Value FROM (SELECT `Attributes`, `anchor_ts`, arraySort(groupArray((`_src_ts`, `Value`))) AS window_pairs FROM (SELECT `Attributes`, `_src_ts`, `Value`, arrayJoin(arrayMap(i -> fromUnixTimestamp64Nano(intDiv(toUnixTimestamp64Nano(now64(9)), 60000000000) * 60000000000) - toIntervalNanosecond(i * 60000000000), range(greatest(0, intDiv(dateDiff('nanosecond', `_src_ts`, fromUnixTimestamp64Nano(intDiv(toUnixTimestamp64Nano(now64(9)), 60000000000) * 60000000000)) - 300000000000, toInt64(60000000000)) - (modulo(dateDiff('nanosecond', `_src_ts`, fromUnixTimestamp64Nano(intDiv(toUnixTimestamp64Nano(now64(9)), 60000000000) * 60000000000)) - 300000000000, toInt64(60000000000)) < 0) + 1), least(11, intDiv(dateDiff('nanosecond', `_src_ts`, fromUnixTimestamp64Nano(intDiv(toUnixTimestamp64Nano(now64(9)), 60000000000) * 60000000000)), toInt64(60000000000)) - (modulo(dateDiff('nanosecond', `_src_ts`, fromUnixTimestamp64Nano(intDiv(toUnixTimestamp64Nano(now64(9)), 60000000000) * 60000000000)), toInt64(60000000000)) < 0) + 1)))) AS anchor_ts FROM (SELECT *, `anchor_ts` AS _src_ts FROM (SELECT `Attributes`, `anchor_ts`, anchor_ts AS `TimeUnix`, if(length(window_vals) > 0, window_vals[length(window_vals)], nan) AS `Value` FROM (SELECT `Attributes`, `anchor_ts`, arrayMap(p -> tupleElement(p, 2), window_pairs) AS `window_vals`, arraySum(arrayMap((p, c) -> if(c < p, c, c - p), arrayPopBack(arrayMap(x -> tupleElement(x, 2), window_pairs)), arrayPopFront(arrayMap(x -> tupleElement(x, 2), window_pairs)))) AS `counter_delta` FROM (SELECT `Attributes`, `anchor_ts`, arraySort(groupArray((`TimeUnix`, `Value`))) AS `window_pairs` FROM (SELECT `Attributes`, `TimeUnix`, `Value`, arrayJoin(arrayMap(i -> fromUnixTimestamp64Nano(intDiv(toUnixTimestamp64Nano(now64(9)), 60000000000) * 60000000000) - toIntervalNanosecond(i * 60000000000), range(greatest(0, intDiv(dateDiff('nanosecond', `TimeUnix`, fromUnixTimestamp64Nano(intDiv(toUnixTimestamp64Nano(now64(9)), 60000000000) * 60000000000)) - 60000000000, toInt64(60000000000)) - (modulo(dateDiff('nanosecond', `TimeUnix`, fromUnixTimestamp64Nano(intDiv(toUnixTimestamp64Nano(now64(9)), 60000000000) * 60000000000)) - 60000000000, toInt64(60000000000)) < 0) + 1), least(16, intDiv(dateDiff('nanosecond', `TimeUnix`, fromUnixTimestamp64Nano(intDiv(toUnixTimestamp64Nano(now64(9)), 60000000000) * 60000000000)), toInt64(60000000000)) - (modulo(dateDiff('nanosecond', `TimeUnix`, fromUnixTimestamp64Nano(intDiv(toUnixTimestamp64Nano(now64(9)), 60000000000) * 60000000000)), toInt64(60000000000)) < 0) + 1)))) AS `anchor_ts` FROM (SELECT * FROM merge(currentDatabase(), '^(otel_metrics_gauge|otel_metrics_sum)$') WHERE (`MetricName` = ?))) GROUP BY `Attributes`, `anchor_ts`)) WHERE length(`window_vals`) >= 1))) GROUP BY `Attributes`, `anchor_ts`) WHERE length(`window_pairs`) >= 2) WHERE `anchor_ts` > now64(9) - toIntervalNanosecond(600000000000) AND `anchor_ts` <= now64(9) GROUP BY `Attributes`
