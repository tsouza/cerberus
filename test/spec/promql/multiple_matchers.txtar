-- query.promql --
up{job="api",env="prod"}
-- sql --
SELECT * FROM `otel_metrics_gauge` PREWHERE (`MetricName` = ?) AND (`Attributes`[?] = ?) WHERE (`Attributes`[?] = ?)
-- args --
[0] string = "up"
[1] string = "job"
[2] string = "api"
[3] string = "env"
[4] string = "prod"
-- chplan --
Filter predicate=(((Attributes["job"] = "api") AND (Attributes["env"] = "prod")) AND (MetricName = "up"))
  Scan(otel_metrics_gauge)
