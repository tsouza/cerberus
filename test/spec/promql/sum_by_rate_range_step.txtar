# Regression: `sum by (X) (rate(metric[range]))` in range mode (Step > 0)
# used to fail at CH with `Unknown expression identifier 'bucket_ts'` —
# the inner Aggregate's `TimeUnix AS bucket_ts` projection had no
# `TimeUnix` column to read from because the rate emitter's matrix
# outer SELECT only surfaced `anchor_ts`. The fix projects an additional
# `anchor_ts AS TimeUnix` alias so the wrapping Aggregate's per-step
# GROUP BY (ColumnRef{TimestampColumn}, see internal/promql/lower.go
# `bucket_ts` branch) resolves. The cerberus dashboard's
# request-rate panel exercises exactly this shape.

-- query.promql --
sum by(cerberus_ql) (rate(cerberus_queries_total[5m]))
-- range_step --
30s
-- seed --
CREATE TABLE otel_metrics_sum (
    MetricName String,
    Attributes Map(String, String),
    TimeUnix DateTime64(9),
    Value Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
INSERT INTO otel_metrics_sum VALUES
    ('cerberus_queries_total', map('cerberus_ql', 'promql'), toDateTime64('2026-01-01 00:00:00', 9), 0.0),
