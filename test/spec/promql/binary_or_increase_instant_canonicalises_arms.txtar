# Regression: an INSTANT-mode PromQL `or` chain over `increase(metric[range])`
# arms (no `range_step`, i.e. Step == 0 on the RangeWindow) used to fail
# at ClickHouse with
#
#     code: 47, message: Unknown expression identifier 'TimeUnix' in scope
#     SELECT '' AS MetricName, Attributes, TimeUnix, Value FROM (...)
#
# or, when the planner could still locate a `TimeUnix` symbol in an
# enclosing scope,
#
#     code: 1, message: Resolve identifier 'TimeUnix' from parent scope
#     only supported for constants and CTE. Actual TimeUnix node type COLUMN.
#
# — surfaced by PR #701's new `otelcol-observability` dashboard's
# "Send failures (5m)" + "Processor refusals (5m)" stat panels, which
# Grafana renders as an instant-mode `query` request (no step), not a
# `query_range`.
#
# Root cause: PR #706's `vectorSetOpCanonicalArmFrag` always projected
# every arm as `SELECT <metricNameFrag>, Attributes, TimeUnix, Value
# FROM (<arm>)`. For derived-shape arms (instant-mode RangeWindow /
# Aggregate / MetricsAggregate / MetricsHistogramOverTime) the inner
# SELECT only exposes `(group-keys..., Value)` — no `TimeUnix` column —
# so CH rejects the canonical-shape SELECT's `TimeUnix` reference.
#
# The matrix-mode (range-step) case sets `anchor_ts AS TimeUnix` on
# the inner SELECT (see emitWindowedArrayPairsMatrix /
# emitWindowedArrayMatrix), so the canonical-shape SELECT above it can
# reference TimeUnix as a real column. Only instant-mode arms hit the
# missing-column path — covered by this fixture; matrix-mode arms are
# covered by the sister fixture `binary_or_increase_range_canonicalises_arms.txtar`.
#
# Fix: `vectorSetOpCanonicalArmFrag` now synthesises `now64(9) -
# toIntervalNanosecond(5000000000) AS TimeUnix` for derived-shape,
# instant-mode arms — mirroring `wrapWithSampleProjection`'s instant
# branch in internal/api/prom/handler.go. Matrix-mode arms (OuterRange
# > 0) still reference TimeUnix by name.

-- query.promql --
sum(increase(otelcol_exporter_send_failed_log_records[5m]) or increase(otelcol_exporter_send_failed_metric_points[5m]) or increase(otelcol_exporter_send_failed_spans[5m]))
-- seed --
CREATE TABLE otel_metrics_gauge (
    MetricName String,
    Attributes Map(String, String),
    TimeUnix DateTime64(9),
    Value Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
INSERT INTO otel_metrics_gauge VALUES
    ('otelcol_exporter_send_failed_log_records',     map('exporter', 'otlp'), toDateTime64('2026-01-01 00:00:00', 9),  0.0),
    ('otelcol_exporter_send_failed_log_records',     map('exporter', 'otlp'), toDateTime64('2026-01-01 00:05:00', 9),  5.0),
    ('otelcol_exporter_send_failed_metric_points',   map('exporter', 'otlp'), toDateTime64('2026-01-01 00:00:00', 9),  0.0),
    ('otelcol_exporter_send_failed_metric_points',   map('exporter', 'otlp'), toDateTime64('2026-01-01 00:05:00', 9), 10.0),
    ('otelcol_exporter_send_failed_spans',           map('exporter', 'otlp'), toDateTime64('2026-01-01 00:00:00', 9),  0.0),
    ('otelcol_exporter_send_failed_spans',           map('exporter', 'otlp'), toDateTime64('2026-01-01 00:05:00', 9),  3.0);
-- args --
[0] string = ""
[1] string = "Map(String,String)"
[2] int64 = 9
[3] string = ""
[4] string = "otelcol_exporter_send_failed_log_records"
[5] string = ""
[6] string = "otelcol_exporter_send_failed_metric_points"
[7] string = "otelcol_exporter_send_failed_log_records"
[8] string = ""
[9] string = "otelcol_exporter_send_failed_spans"
[10] string = ""
[11] string = "otelcol_exporter_send_failed_log_records"
[12] string = ""
[13] string = "otelcol_exporter_send_failed_metric_points"
[14] string = "otelcol_exporter_send_failed_log_records"
-- chplan --
Project ["" AS MetricName, CAST(map(), "Map(String,String)") AS Attributes, now64(9) AS TimeUnix, Value AS Value]
  Aggregate groupBy=[] funcs=[sum(Value) AS Value]
    VectorSetOp op=or match=default
      VectorSetOp op=or match=default
        RangeWindow func=increase range=5m0s step=0s ts=TimeUnix value=Value groupBy=[Attributes]
          Filter predicate=(MetricName = "otelcol_exporter_send_failed_log_records")
            Scan(otel_metrics_gauge)
        RangeWindow func=increase range=5m0s step=0s ts=TimeUnix value=Value groupBy=[Attributes]
          Filter predicate=(MetricName = "otelcol_exporter_send_failed_metric_points")
            Scan(otel_metrics_gauge)
      RangeWindow func=increase range=5m0s step=0s ts=TimeUnix value=Value groupBy=[Attributes]
        Filter predicate=(MetricName = "otelcol_exporter_send_failed_spans")
          Scan(otel_metrics_gauge)
-- sql --
SELECT ? AS `MetricName`, CAST(map(), ?) AS `Attributes`, now64(?) AS `TimeUnix`, `Value` AS `Value` FROM (SELECT `Value` FROM (SELECT sum(`Value`) AS `Value`, count() AS `_cerb_n` FROM (SELECT `MetricName`, `Attributes`, `TimeUnix`, `Value` FROM ((SELECT `MetricName`, `Attributes`, `TimeUnix`, `Value` FROM (SELECT `MetricName`, `Attributes`, `TimeUnix`, `Value` FROM (SELECT `MetricName`, `Attributes`, `TimeUnix`, `Value` FROM ((SELECT `MetricName`, `Attributes`, `TimeUnix`, `Value` FROM (SELECT ? AS `MetricName`, `Attributes`, (now64(9) - toIntervalNanosecond(5000000000)) AS `TimeUnix`, `Value` FROM (SELECT `Attributes`, if(sampled_interval > 0, counter_delta * (sampled_interval + if(counter_delta > 0 AND first_val >= 0, least(duration_to_start, sampled_interval * first_val / counter_delta), duration_to_start) + duration_to_end) / sampled_interval, nan) AS `Value` FROM (SELECT `Attributes`, `window_vals`, `counter_delta`, `first_val`, toFloat64(dateDiff('nanosecond', first_ts, last_ts)) / 1e9 AS `sampled_interval`, if(toFloat64(dateDiff('nanosecond', now64(9) - toIntervalNanosecond(300000000000), first_ts)) / 1e9 >= 1.1 * sampled_interval / (length(window_vals) - 1), sampled_interval / (length(window_vals) - 1) / 2, toFloat64(dateDiff('nanosecond', now64(9) - toIntervalNanosecond(300000000000), first_ts)) / 1e9) AS `duration_to_start`, if(toFloat64(dateDiff('nanosecond', last_ts, now64(9))) / 1e9 >= 1.1 * sampled_interval / (length(window_vals) - 1), sampled_interval / (length(window_vals) - 1) / 2, toFloat64(dateDiff('nanosecond', last_ts, now64(9))) / 1e9) AS `duration_to_end` FROM (SELECT `Attributes`, arrayMap(p -> tupleElement(p, 2), window_pairs) AS `window_vals`, arraySum(arrayMap((p, c) -> if(c < p, c, c - p), arrayPopBack(arrayMap(x -> tupleElement(x, 2), window_pairs)), arrayPopFront(arrayMap(x -> tupleElement(x, 2), window_pairs)))) AS `counter_delta`, tupleElement(window_pairs[1], 1) AS `first_ts`, tupleElement(window_pairs[length(window_pairs)], 1) AS `last_ts`, tupleElement(window_pairs[1], 2) AS `first_val` FROM (SELECT `Attributes`, arrayFilter(p -> tupleElement(p, 1) > now64(9) - toIntervalNanosecond(300000000000) AND tupleElement(p, 1) <= now64(9), series_array) AS `window_pairs` FROM (SELECT `Attributes`, arraySort(groupArray((`TimeUnix`, `Value`))) AS `series_array` FROM (SELECT * FROM `otel_metrics_gauge` WHERE (`MetricName` = ?)) GROUP BY `Attributes`)))) WHERE length(`window_vals`) >= 2))) UNION ALL (SELECT `MetricName`, `Attributes`, `TimeUnix`, `Value` FROM (SELECT ? AS `MetricName`, `Attributes`, (now64(9) - toIntervalNanosecond(5000000000)) AS `TimeUnix`, `Value` FROM (SELECT `Attributes`, if(sampled_interval > 0, counter_delta * (sampled_interval + if(counter_delta > 0 AND first_val >= 0, least(duration_to_start, sampled_interval * first_val / counter_delta), duration_to_start) + duration_to_end) / sampled_interval, nan) AS `Value` FROM (SELECT `Attributes`, `window_vals`, `counter_delta`, `first_val`, toFloat64(dateDiff('nanosecond', first_ts, last_ts)) / 1e9 AS `sampled_interval`, if(toFloat64(dateDiff('nanosecond', now64(9) - toIntervalNanosecond(300000000000), first_ts)) / 1e9 >= 1.1 * sampled_interval / (length(window_vals) - 1), sampled_interval / (length(window_vals) - 1) / 2, toFloat64(dateDiff('nanosecond', now64(9) - toIntervalNanosecond(300000000000), first_ts)) / 1e9) AS `duration_to_start`, if(toFloat64(dateDiff('nanosecond', last_ts, now64(9))) / 1e9 >= 1.1 * sampled_interval / (length(window_vals) - 1), sampled_interval / (length(window_vals) - 1) / 2, toFloat64(dateDiff('nanosecond', last_ts, now64(9))) / 1e9) AS `duration_to_end` FROM (SELECT `Attributes`, arrayMap(p -> tupleElement(p, 2), window_pairs) AS `window_vals`, arraySum(arrayMap((p, c) -> if(c < p, c, c - p), arrayPopBack(arrayMap(x -> tupleElement(x, 2), window_pairs)), arrayPopFront(arrayMap(x -> tupleElement(x, 2), window_pairs)))) AS `counter_delta`, tupleElement(window_pairs[1], 1) AS `first_ts`, tupleElement(window_