    Aggregate groupBy=[MetricName AS MetricName, Attributes AS Attributes] funcs=[max(TimeUnix) AS lwr_ts, argMax(Value, TimeUnix) AS lwr_value]
      Filter predicate=((((((((((((((((((MetricName = "http_server_request_b_total") OR (MetricName = "http.server.request.b.total")) OR (MetricName = "http.server.request.b_total")) OR (MetricName = "http.server.request_b.total")) OR (MetricName = "http.server.request_b_total")) OR (MetricName = "http.server_request.b.total")) OR (MetricName = "http.server_request.b_total")) OR (MetricName = "http.server_request_b.total")) OR (MetricName = "http.server_request_b_total")) OR (MetricName = "http_server.request.b.total")) OR (MetricName = "http_server.request.b_total")) OR (MetricName = "http_server.request_b.total")) OR (MetricName = "http_server.request_b_total")) OR (MetricName = "http_server_request.b.total")) OR (MetricName = "http_server_request.b_total")) OR (MetricName = "http_server_request_b.total")) AND (TimeUnix <= toDateTime64("2026-01-01 00:00:01.000000000", 9))) AND (TimeUnix > (toDateTime64("2026-01-01 00:00:01.000000000", 9) - toIntervalNanosecond(300000000000))))
