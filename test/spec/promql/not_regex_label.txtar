-- query.promql --
up{job!~"backend.*"}
-- sql --
SELECT * FROM `otel_metrics_gauge` PREWHERE (`MetricName` = ?) WHERE NOT match(`Attributes`[?], ?)
-- args --
[0] string = "up"
[1] string = "job"
[2] string = "backend.*"
-- chplan --
Filter predicate=((Attributes["job"] !~ "backend.*") AND (MetricName = "up"))
  Scan(otel_metrics_gauge)
