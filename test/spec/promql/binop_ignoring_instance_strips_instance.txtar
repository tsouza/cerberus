-- query.promql --
metric_a / ignoring(instance) metric_b
-- seed --
CREATE TABLE otel_metrics_sum (
    MetricName String,
    Attributes Map(String, String),
    TimeUnix DateTime64(9),
    Value Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
INSERT INTO otel_metrics_sum VALUES
    ('metric_a', map('job', 'api', 'instance', 'a'), toDateTime64('2026-01-01 00:00:00', 9), 100.0),
    ('metric_b', map('job', 'api', 'instance', 'b'), toDateTime64('2026-01-01 00:00:00', 9), 25.0);
