-- chplan --
VectorJoin op=/ match=default card=one-to-one
  Project [Attributes, anchor_ts, TimeUnix AS TimeUnix, (100 * Value) AS Value]
    RangeWindow func=rate range=5m0s step=30s outerRange=5m0s ts=TimeUnix value=Value groupBy=[Attributes] start=2026-01-01T00:00:00Z end=2026-01-01T00:05:00Z
      Project [MetricName AS MetricName, mapUpdate(mapFromArrays(arrayMap(k -> replaceRegexpAll(k, "[^a-zA-Z0-9_]", "_"), mapKeys(mapFilter((k, v) -> (k NOT IN ("service.name", "service_name")), ResourceAttributes))), mapValues(mapFilter((k, v) -> (k NOT IN ("service.name", "service_name")), ResourceAttributes))), mapFromArrays(arrayMap(k -> replaceRegexpAll(k, "[^a-zA-Z0-9_]", "_"), mapKeys(Attributes)), mapValues(Attributes))) AS Attributes, TimeUnix AS TimeUnix, Value AS Value]
        Filter predicate=(MetricName IN ("redis_keyspace_hits", "redis.keyspace.hits", "redis.keyspace/hits", "redis.keyspace_hits", "redis/keyspace/hits", "redis/keyspace_hits", "redis_keyspace.hits"))
          Scan(merge(otel_metrics_gauge|otel_metrics_sum))
  VectorJoin op=+ match=default card=one-to-one
    RangeWindow func=rate range=5m0s step=30s outerRange=5m0s ts=TimeUnix value=Value groupBy=[Attributes] start=2026-01-01T00:00:00Z end=2026-01-01T00:05:00Z
      Project [MetricName AS MetricName, mapUpdate(mapFromArrays(arrayMap(k -> replaceRegexpAll(k, "[^a-zA-Z0-9_]", "_"), mapKeys(mapFilter((k, v) -> (k NOT IN ("service.name", "service_name")), ResourceAttributes))), mapValues(mapFilter((k, v) -> (k NOT IN ("service.name", "service_name")), ResourceAttributes))), mapFromArrays(arrayMap(k -> replaceRegexpAll(k, "[^a-zA-Z0-9_]", "_"), mapKeys(Attributes)), mapValues(Attributes))) AS Attributes, TimeUnix AS TimeUnix, Value AS Value]
        Filter predicate=(MetricName IN ("redis_keyspace_hits", "redis.keyspace.hits", "redis.keyspace/hits", "redis.keyspace_hits", "redis/keyspace/hits", "redis/keyspace_hits", "redis_keyspace.hits"))
          Scan(merge(otel_metrics_gauge|otel_metrics_sum))
    RangeWindow func=rate range=5m0s step=30s outerRange=5m0s ts=TimeUnix value=Value groupBy=[Attributes] start=2026-01-01T00:00:00Z end=2026-01-01T00:05:00Z
      Project [MetricName AS MetricName, mapUpdate(mapFromArrays(arrayMap(k -> replaceRegexpAll(k, "[^a-zA-Z0-9_]", "_"), mapKeys(mapFilter((k, v) -> (k NOT IN ("service.name", "service_name")), ResourceAttributes))), mapValues(mapFilter((k, v) -> (k NOT IN ("service.name", "service_name")), ResourceAttributes))), mapFromArrays(arrayMap(k -> replaceRegexpAll(k, "[^a-zA-Z0-9_]", "_"), mapKeys(Attributes)), mapValues(Attributes))) AS Attributes, TimeUnix AS TimeUnix, Value AS Value]
        Filter predicate=(MetricName IN ("redis_keyspace_misses", "redis.keyspace.misses", "redis.keyspace/misses", "redis.keyspace_misses", "redis/keyspace/misses", "redis/keyspace_misses", "redis_keyspace.misses"))
          Scan(merge(otel_metrics_gauge|otel_metrics_sum))
-- sql --
