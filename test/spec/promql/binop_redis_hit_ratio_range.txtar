# Regression (real prod-aws crash): the redis cache-hit-ratio query
#   100 * rate(hits[5m]) / (rate(hits[5m]) + rate(misses[5m]))
# range query, step 15s, crashed strict clickhouse-go with code 47
# `Unknown expression identifier '_join_TimeUnix'`. Precedence is
# `(100 * rate(hits)) / (rate(hits) + rate(misses))`: the left arm of the
# outer `/` is the scalar-vector arithmetic Project (`100 * rate`). In range
# mode that Project dropped `TimeUnix` even though the matrix RangeWindow
# surfaces it (`anchor_ts AS TimeUnix`), so the step-aligned VectorJoin's
# `argMax(Value, TimeUnix)` / `_join_TimeUnix` aliases referenced a missing
# column. The fix forwards `TimeUnix` through the matrix value-rewrite Project.
#
# Value identity: hits rate = 12/min over 60s = 0.2/s; misses rate = 4/min =
# 0.0666.../s; ratio = 100 * 0.2 / (0.2 + 0.0666...) = 75. The chDB roundtrip
# below executes the SQL and proves the column resolves end to end.

-- query.promql --
100 * rate(redis_keyspace_hits[5m]) / (rate(redis_keyspace_hits[5m]) + rate(redis_keyspace_misses[5m]))
-- range_step --
30s
-- seed --
CREATE TABLE otel_metrics_sum (
    MetricName String,
    Attributes Map(String, String),
    TimeUnix DateTime64(9),
    Value Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
INSERT INTO otel_metrics_sum VALUES
    ('redis_keyspace_hits', map('instance', 'r1'), toDateTime64('2026-01-01 00:00:00', 9), 0.0),
