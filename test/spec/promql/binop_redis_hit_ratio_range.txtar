    ('redis_keyspace_hits', map('instance', 'r1'), toDateTime64('2026-01-01 00:03:00', 9), 36.0),
    ('redis_keyspace_hits', map('instance', 'r1'), toDateTime64('2026-01-01 00:04:00', 9), 48.0),
    ('redis_keyspace_hits', map('instance', 'r1'), toDateTime64('2026-01-01 00:05:00', 9), 60.0),
    ('redis_keyspace_misses', map('instance', 'r1'), toDateTime64('2026-01-01 00:00:00', 9), 0.0),
    ('redis_keyspace_misses', map('instance', 'r1'), toDateTime64('2026-01-01 00:01:00', 9), 4.0),
    ('redis_keyspace_misses', map('instance', 'r1'), toDateTime64('2026-01-01 00:02:00', 9), 8.0),
    ('redis_keyspace_misses', map('instance', 'r1'), toDateTime64('2026-01-01 00:03:00', 9), 12.0),
    ('redis_keyspace_misses', map('instance', 'r1'), toDateTime64('2026-01-01 00:04:00', 9), 16.0),
    ('redis_keyspace_misses', map('instance', 'r1'), toDateTime64('2026-01-01 00:05:00', 9), 20.0);
