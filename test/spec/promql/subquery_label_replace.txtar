-- query.promql --
max_over_time(label_replace(up, "env", "prod", "job", ".*")[5m:1m])
-- seed --
CREATE TABLE otel_metrics_gauge (
    MetricName String,
    Attributes Map(String, String),
    TimeUnix DateTime64(9),
    Value Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
INSERT INTO otel_metrics_gauge VALUES
    ('up', map('job', 'api'), toDateTime64('2025-12-31 23:56:00', 9), 10),
    ('up', map('job', 'api'), toDateTime64('2025-12-31 23:58:00', 9), 20),
    ('up', map('job', 'api'), toDateTime64('2026-01-01 00:00:00', 9), 30);
-- expected_rows --
[
  [{"env": "prod", "job": "api"}, 30]
]
-- args --
[0] string = "job"
[1] string = "^.*$"
[2] string = "env"
[3] string = "job"
[4] string = "prod"
[5] string = "job"
[6] string = "^.*$"
[7] string = "prod"
[8] string = "up"
-- chplan --
RangeWindow func=max_over_time range=5m0s step=0s ts=anchor_ts value=Value groupBy=[Attributes]
  RangeWindow func= range=1m0s step=1m0s outerRange=5m0s identity=true ts=TimeUnix value=Value groupBy=[Attributes]
    Project [MetricName, labelReplace(Attributes, dst="env", replacement="prod", src="job", regex=".*", emptyReplacement="prod") AS Attributes, TimeUnix, Value]
      Filter predicate=(MetricName = "up")
        Scan(merge(otel_metrics_gauge|otel_metrics_sum))
-- sql --
SELECT `Attributes`, if(length(window_vals) > 0, arrayMax(window_vals), nan) AS `Value` FROM (SELECT `Attributes`, arrayMap(p -> tupleElement(p, 2), window_pairs) AS `window_vals`, arraySum(arrayMap((p, c) -> if(c < p, c, c - p), arrayPopBack(arrayMap(x -> tupleElement(x, 2), window_pairs)), arrayPopFront(arrayMap(x -> tupleElement(x, 2), window_pairs)))) AS `counter_delta` FROM (SELECT `Attributes`, arrayFilter(p -> tupleElement(p, 1) > now64(9) - toIntervalNanosecond(300000000000) AND tupleElement(p, 1) <= now64(9), series_array) AS `window_pairs` FROM (SELECT `Attributes`, arraySort(groupArray((`anchor_ts`, `Value`))) AS `series_array` FROM (SELECT `Attributes`, `anchor_ts`, anchor_ts AS `TimeUnix`, if(length(window_vals) > 0, window_vals[length(window_vals)], nan) AS `Value` FROM (SELECT `Attributes`, `anchor_ts`, arrayMap(p -> tupleElement(p, 2), window_pairs) AS `window_vals`, arraySum(arrayMap((p, c) -> if(c < p, c, c - p), arrayPopBack(arrayMap(x -> tupleElement(x, 2), window_pairs)), arrayPopFront(arrayMap(x -> tupleElement(x, 2), window_pairs)))) AS `counter_delta` FROM (SELECT `Attributes`, `anchor_ts`, arraySort(groupArray((`TimeUnix`, `Value`))) AS `window_pairs` FROM (SELECT `Attributes`, `TimeUnix`, `Value`, arrayJoin(arrayMap(i -> now64(9) - toIntervalNanosecond(i * 60000000000), range(greatest(0, intDiv(dateDiff('nanosecond', `TimeUnix`, now64(9)) - 60000000000, toInt64(60000000000)) - (modulo(dateDiff('nanosecond', `TimeUnix`, now64(9)) - 60000000000, toInt64(60000000000)) < 0) + 1), least(6, intDiv(dateDiff('nanosecond', `TimeUnix`, now64(9)), toInt64(60000000000)) - (modulo(dateDiff('nanosecond', `TimeUnix`, now64(9)), toInt64(60000000000)) < 0) + 1)))) AS `anchor_ts` FROM (SELECT `MetricName`, mapFilter((k, v) -> v != '', if(match(`Attributes`[?], ?), mapUpdate(`Attributes`, map(?, if(empty(`Attributes`[?]), ?, replaceRegexpOne(`Attributes`[?], ?, ?)))), `Attributes`)) AS `Attributes`, `TimeUnix`, `Value` FROM (SELECT * FROM merge(currentDatabase(), '^(otel_metrics_gauge|otel_metrics_sum)$') WHERE (`MetricName` = ?)))) GROUP BY `Attributes`, `anchor_ts`)) WHERE length(`window_vals`) >= 1) GROUP BY `Attributes`))) WHERE length(`window_vals`) >= 1
