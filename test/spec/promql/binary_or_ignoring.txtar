-- query.promql --
http_server_request_a_total or ignoring(instance) http_server_request_b_total
-- seed --
CREATE TABLE otel_metrics_sum (
    MetricName String,
    Attributes Map(String, String),
    TimeUnix DateTime64(9),
    Value Float64
) ENGINE = MergeTree ORDER BY (MetricName, Attributes, TimeUnix);
INSERT INTO otel_metrics_sum VALUES
    ('http_server_request_a_total', map('job', 'api',   'instance', 'i-1'), toDateTime64('2026-01-01 00:00:00', 9), 10.0),
    ('http_server_request_b_total',   map('job', 'api',   'instance', 'i-2'), toDateTime64('2026-01-01 00:00:00', 9), 25.0),
    ('http_server_request_b_total',   map('job', 'extra', 'instance', 'i-3'), toDateTime64('2026-01-01 00:00:00', 9), 50.0);
