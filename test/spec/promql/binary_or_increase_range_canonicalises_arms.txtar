Project ["" AS MetricName, CAST(map(), "Map(String,String)") AS Attributes, bucket_ts AS TimeUnix, Value AS Value]
  Aggregate groupBy=[TimeUnix AS bucket_ts] funcs=[sum(Value) AS Value]
    VectorSetOp op=or match=default
      VectorSetOp op=or match=default
        RangeWindow func=increase range=5m0s step=1m0s outerRange=5m0s ts=TimeUnix value=Value groupBy=[Attributes] start=2026-01-01T00:00:00Z end=2026-01-01T00:05:00Z
          Filter predicate=(MetricName IN ("otelcol_processor_refused_log_records", "otelcol.processor.refused.log.records", "otelcol.processor.refused.log_records", "otelcol.processor.refused_log.records", "otelcol.processor.refused_log_records", "otelcol.processor_refused.log.records", "otelcol.processor_refused.log_records", "otelcol.processor_refused_log.records", "otelcol.processor_refused_log_records", "otelcol_processor.refused.log.records", "otelcol_processor.refused.log_records", "otelcol_processor.refused_log.records", "otelcol_processor.refused_log_records", "otelcol_processor_refused.log.records", "otelcol_processor_refused.log_records", "otelcol_processor_refused_log.records"))
