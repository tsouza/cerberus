-- args --
[0] int64 = 9
-- sql --
SELECT `Timestamp`, `SeverityNumber`, `ServiceName` FROM (SELECT * FROM (SELECT * FROM `otel_logs` WHERE (`SeverityNumber` >= ?)) LIMIT 100)
-- chplan --
Project [Timestamp, SeverityNumber, ServiceName]
  Limit 100
    Filter predicate=(SeverityNumber >= 9)
      Scan(otel_logs)
