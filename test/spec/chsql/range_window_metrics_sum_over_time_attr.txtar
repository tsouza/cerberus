-- args --
(none)
-- sql --
SELECT `anchor_ts`, toFloat64(sum(`metric_arg`)) AS `Value` FROM (SELECT `Duration` AS `metric_arg`, arrayJoin(arrayMap(i -> now64(9) - toIntervalNanosecond(i * 60000000000), range(greatest(0, intDiv(dateDiff('nanosecond', `Timestamp`, now64(9)) - 60000000000, toInt64(60000000000)) - (modulo(dateDiff('nanosecond', `Timestamp`, now64(9)) - 60000000000, toInt64(60000000000)) < 0) + 1), least(6, intDiv(dateDiff('nanosecond', `Timestamp`, now64(9)), toInt64(60000000000)) - (modulo(dateDiff('nanosecond', `Timestamp`, now64(9)), toInt64(60000000000)) < 0) + 1)))) AS `anchor_ts` FROM (SELECT * FROM `otel_traces`)) GROUP BY `anchor_ts`
-- chplan --
RangeWindow func= range=0s step=1m0s outerRange=5m0s ts=Timestamp
  MetricsAggregate op=sum_over_time attr=Duration valueAlias=Value
    Scan(otel_traces)
