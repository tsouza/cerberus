-- sql --
SELECT * FROM (SELECT `Attributes`, toFloat64(count(?)) AS `Value` FROM (SELECT * FROM `otel_metrics_gauge`) GROUP BY `Attributes`) WHERE (`Value` > ?)
-- args --
[0] int64 = 1
[1] int64 = 0
-- chplan --
Filter predicate=(Value > 0)
  Aggregate groupBy=[Attributes] funcs=[count(1) AS Value]
    Scan(otel_metrics_gauge)
