-- args --
(none)
-- sql --
SELECT `Attributes`, max(`Value`) AS `Value` FROM (SELECT * FROM `otel_metrics_gauge`) WHERE `TimeUnix` > now64(9) - toIntervalNanosecond(300000000000) AND `TimeUnix` <= now64(9) GROUP BY `Attributes`
-- chplan --
RangeWindow func=max_over_time range=5m0s step=0s ts=TimeUnix value=Value groupBy=[Attributes]
  Scan(otel_metrics_gauge)
