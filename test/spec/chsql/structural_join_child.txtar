-- sql --
SELECT R.`TraceId` AS `TraceId`, R.`SpanId` AS `SpanId`, R.`ParentSpanId` AS `ParentSpanId`, R.* EXCEPT (`TraceId`, `SpanId`, `ParentSpanId`) FROM (SELECT * FROM `otel_traces`) AS L INNER JOIN (SELECT * FROM `otel_traces`) AS R ON L.`TraceId` = R.`TraceId` AND L.`SpanId` = R.`ParentSpanId`
-- args --
(none)
-- chplan --
StructuralJoin op=>
  Scan(otel_traces)
  Scan(otel_traces)
