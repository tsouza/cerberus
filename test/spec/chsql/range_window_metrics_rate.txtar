-- args --
(none)
-- sql --
SELECT `anchor_ts`, toFloat64(sum(in_window)) / 300 AS `Value` FROM ((SELECT arrayJoin(arrayMap(i -> now64(9) - toIntervalNanosecond(i * 60000000000), range(greatest(0, intDiv(dateDiff('nanosecond', `Timestamp`, now64(9)) - 300000000000, toInt64(60000000000)) - (modulo(dateDiff('nanosecond', `Timestamp`, now64(9)) - 300000000000, toInt64(60000000000)) < 0) + 1), least(61, intDiv(dateDiff('nanosecond', `Timestamp`, now64(9)), toInt64(60000000000)) - (modulo(dateDiff('nanosecond', `Timestamp`, now64(9)), toInt64(60000000000)) < 0) + 1)))) AS `anchor_ts`, 1 AS `in_window` FROM (SELECT * FROM `otel_traces`)) UNION ALL (SELECT arrayJoin(arrayMap(i -> now64(9) - toIntervalNanosecond(i * 60000000000), range(0, 61))) AS `anchor_ts`, 0 AS `in_window` FROM (SELECT 1 FROM `system`.`one`))) GROUP BY `anchor_ts`
-- chplan --
RangeWindow func= range=5m0s step=1m0s outerRange=1h0m0s ts=Timestamp
  MetricsAggregate op=rate valueAlias=Value
    Scan(otel_traces)
