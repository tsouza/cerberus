-- sql --
SELECT * FROM `otel_metrics_gauge` PREWHERE (`MetricName` = ?) WHERE (((`job` = ?) AND (`Value` > ?)) OR (`MetricName` = ?))
-- args --
[0] string = "up"
[1] string = "api"
[2] float64 = 0.5
[3] string = "down"
-- chplan --
Filter predicate=((MetricName = "up") AND (((job = "api") AND (Value > 0.5)) OR (MetricName = "down")))
  Scan(otel_metrics_gauge)
