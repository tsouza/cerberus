-- unoptimized --
SELECT * FROM (SELECT * FROM (SELECT * FROM `otel_metrics_gauge` PREWHERE (`MetricName` = ?)) WHERE (`job` = ?)) WHERE (`Value` > toFloat64(?))
-- optimized --
SELECT * FROM `otel_metrics_gauge` PREWHERE (`MetricName` = ?) AND (`job` = ?) WHERE (`Value` > toFloat64(?))
-- chplan_optimized --
Filter predicate=(((MetricName = "up") AND (job = "api")) AND (Value > 0))
  Scan(otel_metrics_gauge)
-- chplan_unoptimized --
Filter predicate=(Value > 0)
  Filter predicate=(job = "api")
    Filter predicate=(MetricName = "up")
      Scan(otel_metrics_gauge)
