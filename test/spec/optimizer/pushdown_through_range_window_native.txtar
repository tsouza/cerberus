-- chplan_optimized --
RangeWindowNative func=rate range=5m0s step=30s ts=TimeUnix value=Value groupBy=[Attributes] start=1970-01-01T00:16:40Z end=1970-01-01T00:21:40Z
  Filter predicate=(MetricName = "http_requests_total")
    Scan(otel_metrics_sum, columns=[Attributes, MetricName, TimeUnix, Value])
-- chplan_unoptimized --
RangeWindowNative func=rate range=5m0s step=30s ts=TimeUnix value=Value groupBy=[Attributes] start=1970-01-01T00:16:40Z end=1970-01-01T00:21:40Z
  Filter predicate=(MetricName = "http_requests_total")
    Scan(otel_metrics_sum)
-- optimized --
SELECT `Attributes`, `anchor_ts`, `anchor_ts` AS `TimeUnix`, toFloat64(assumeNotNull(`grid_val`)) AS `Value` FROM (SELECT `Attributes`, timeSeriesRateToGrid(toDateTime(1000, 'UTC'), toDateTime(1300, 'UTC'), 30, 300)(`TimeUnix`, `Value`) AS `grid`, timeSeriesRange(toDateTime(1000, 'UTC'), toDateTime(1300, 'UTC'), 30) AS `grid_ts` FROM (SELECT `Attributes`, `MetricName`, `TimeUnix`, `Value` FROM `otel_metrics_sum` WHERE (`MetricName` = ?)) WHERE `TimeUnix` > toDateTime64('1970-01-01 00:16:40.000000000', 9) - toIntervalNanosecond(300000000000) AND `TimeUnix` <= toDateTime64('1970-01-01 00:21:40.000000000', 9) GROUP BY `Attributes`) ARRAY JOIN `grid` AS `grid_val`, `grid_ts` AS `anchor_ts` WHERE `grid_val` IS NOT NULL
-- unoptimized --
SELECT `Attributes`, `anchor_ts`, `anchor_ts` AS `TimeUnix`, toFloat64(assumeNotNull(`grid_val`)) AS `Value` FROM (SELECT `Attributes`, timeSeriesRateToGrid(toDateTime(1000, 'UTC'), toDateTime(1300, 'UTC'), 30, 300)(`TimeUnix`, `Value`) AS `grid`, timeSeriesRange(toDateTime(1000, 'UTC'), toDateTime(1300, 'UTC'), 30) AS `grid_ts` FROM (SELECT * FROM `otel_metrics_sum` PREWHERE (`MetricName` = ?)) WHERE `TimeUnix` > toDateTime64('1970-01-01 00:16:40.000000000', 9) - toIntervalNanosecond(300000000000) AND `TimeUnix` <= toDateTime64('1970-01-01 00:21:40.000000000', 9) GROUP BY `Attributes`) ARRAY JOIN `grid` AS `grid_val`, `grid_ts` AS `anchor_ts` WHERE `grid_val` IS NOT NULL
