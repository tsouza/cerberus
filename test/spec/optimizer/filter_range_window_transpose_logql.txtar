-- unoptimized --
SELECT * FROM (SELECT `ServiceName`, if(sampled_interval > 0, counter_delta * (sampled_interval + if(counter_delta > 0 AND first_val >= 0, least(duration_to_start, sampled_interval * first_val / counter_delta), duration_to_start) + duration_to_end) / sampled_interval / 300, nan) AS `BodyBytes` FROM (SELECT `ServiceName`, `window_vals`, `counter_delta`, `first_val`, toFloat64(dateDiff('nanosecond', first_ts, last_ts)) / 1e9 AS `sampled_interval`, if(toFloat64(dateDiff('nanosecond', now64(9) - toIntervalNanosecond(300000000000), first_ts)) / 1e9 >= 1.1 * sampled_interval / (length(window_vals) - 1), sampled_interval / (length(window_vals) - 1) / 2, toFloat64(dateDiff('nanosecond', now64(9) - toIntervalNanosecond(300000000000), first_ts)) / 1e9) AS `duration_to_start`, if(toFloat64(dateDiff('nanosecond', last_ts, now64(9))) / 1e9 >= 1.1 * sampled_interval / (length(window_vals) - 1), sampled_interval / (length(window_vals) - 1) / 2, toFloat64(dateDiff('nanosecond', last_ts, now64(9))) / 1e9) AS `duration_to_end` FROM (SELECT `ServiceName`, arrayMap(p -> tupleElement(p, 2), window_pairs) AS `window_vals`, arraySum(arrayMap((p, c) -> if(c < p, c, c - p), arrayPopBack(arrayMap(x -> tupleElement(x, 2), window_pairs)), arrayPopFront(arrayMap(x -> tupleElement(x, 2), window_pairs)))) AS `counter_delta`, tupleElement(window_pairs[1], 1) AS `first_ts`, tupleElement(window_pairs[length(window_pairs)], 1) AS `last_ts`, tupleElement(window_pairs[1], 2) AS `first_val` FROM (SELECT `ServiceName`, arrayFilter((p, i) -> i = length(window_pairs) OR tupleElement(p, 1) != tupleElement(window_pairs[i + 1], 1), window_pairs, arrayEnumerate(window_pairs)) AS `window_pairs` FROM (SELECT `ServiceName`, arrayFilter(p -> tupleElement(p, 1) > now64(9) - toIntervalNanosecond(300000000000) AND tupleElement(p, 1) <= now64(9), series_array) AS `window_pairs` FROM (SELECT `ServiceName`, arraySort(groupArray((`Timestamp`, `BodyBytes`))) AS `series_array` FROM (SELECT * FROM `otel_logs`) GROUP BY `ServiceName`))))) WHERE length(`window_vals`) >= 2) WHERE (`ServiceName` = ?)
-- optimized --
SELECT `ServiceName`, if(sampled_interval > 0, counter_delta * (sampled_interval + if(counter_delta > 0 AND first_val >= 0, least(duration_to_start, sampled_interval * first_val / counter_delta), duration_to_start) + duration_to_end) / sampled_interval / 300, nan) AS `BodyBytes` FROM (SELECT `ServiceName`, `window_vals`, `counter_delta`, `first_val`, toFloat64(dateDiff('nanosecond', first_ts, last_ts)) / 1e9 AS `sampled_interval`, if(toFloat64(dateDiff('nanosecond', now64(9) - toIntervalNanosecond(300000000000), first_ts)) / 1e9 >= 1.1 * sampled_interval / (length(window_vals) - 1), sampled_interval / (length(window_vals) - 1) / 2, toFloat64(dateDiff('nanosecond', now64(9) - toIntervalNanosecond(300000000000), first_ts)) / 1e9) AS `duration_to_start`, if(toFloat64(dateDiff('nanosecond', last_ts, now64(9))) / 1e9 >= 1.1 * sampled_interval / (length(window_vals) - 1), sampled_interval / (length(window_vals) - 1) / 2, toFloat64(dateDiff('nanosecond', last_ts, now64(9))) / 1e9) AS `duration_to_end` FROM (SELECT `ServiceName`, arrayMap(p -> tupleElement(p, 2), window_pairs) AS `window_vals`, arraySum(arrayMap((p, c) -> if(c < p, c, c - p), arrayPopBack(arrayMap(x -> tupleElement(x, 2), window_pairs)), arrayPopFront(arrayMap(x -> tupleElement(x, 2), window_pairs)))) AS `counter_delta`, tupleElement(window_pairs[1], 1) AS `first_ts`, tupleElement(window_pairs[length(window_pairs)], 1) AS `last_ts`, tupleElement(window_pairs[1], 2) AS `first_val` FROM (SELECT `ServiceName`, arrayFilter((p, i) -> i = length(window_pairs) OR tupleElement(p, 1) != tupleElement(window_pairs[i + 1], 1), window_pairs, arrayEnumerate(window_pairs)) AS `window_pairs` FROM (SELECT `ServiceName`, arrayFilter(p -> tupleElement(p, 1) > now64(9) - toIntervalNanosecond(300000000000) AND tupleElement(p, 1) <= now64(9), series_array) AS `window_pairs` FROM (SELECT `ServiceName`, arraySort(groupArray((`Timestamp`, `BodyBytes`))) AS `series_array` FROM (SELECT `BodyBytes`, `ServiceName`, `Timestamp` FROM `otel_logs` WHERE (`ServiceName` = ?)) GROUP BY `ServiceName`))))) WHERE length(`window_vals`) >= 2
-- chplan_optimized --
RangeWindow func=rate range=5m0s step=0s ts=Timestamp value=BodyBytes groupBy=[ServiceName]
  Filter predicate=(ServiceName = "api")
    Scan(otel_logs, columns=[BodyBytes, ServiceName, Timestamp])
-- chplan_unoptimized --
Filter predicate=(ServiceName = "api")
  RangeWindow func=rate range=5m0s step=0s ts=Timestamp value=BodyBytes groupBy=[ServiceName]
    Scan(otel_logs)
