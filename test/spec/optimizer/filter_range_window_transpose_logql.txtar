-- unoptimized --
SELECT * FROM (SELECT `ServiceName`, if(length(window_vals) > 1, counter_delta / 300, 0.0) AS `value` FROM (SELECT `ServiceName`, arrayMap(p -> tupleElement(p, 2), window_pairs) AS `window_vals`, arraySum(arrayMap((p, c) -> if(c < p, c, c - p), arrayPopBack(arrayMap(x -> tupleElement(x, 2), window_pairs)), arrayPopFront(arrayMap(x -> tupleElement(x, 2), window_pairs)))) AS `counter_delta` FROM (SELECT `ServiceName`, arrayFilter(p -> tupleElement(p, 1) >= now64(9) - toIntervalNanosecond(300000000000) AND tupleElement(p, 1) <= now64(9), series_array) AS `window_pairs` FROM (SELECT `ServiceName`, arraySort(groupArray((`Timestamp`, `BodyBytes`))) AS `series_array` FROM (SELECT * FROM `otel_logs`) GROUP BY `ServiceName`)))) WHERE (`ServiceName` = ?)
-- optimized --
SELECT `ServiceName`, if(length(window_vals) > 1, counter_delta / 300, 0.0) AS `value` FROM (SELECT `ServiceName`, arrayMap(p -> tupleElement(p, 2), window_pairs) AS `window_vals`, arraySum(arrayMap((p, c) -> if(c < p, c, c - p), arrayPopBack(arrayMap(x -> tupleElement(x, 2), window_pairs)), arrayPopFront(arrayMap(x -> tupleElement(x, 2), window_pairs)))) AS `counter_delta` FROM (SELECT `ServiceName`, arrayFilter(p -> tupleElement(p, 1) >= now64(9) - toIntervalNanosecond(300000000000) AND tupleElement(p, 1) <= now64(9), series_array) AS `window_pairs` FROM (SELECT `ServiceName`, arraySort(groupArray((`Timestamp`, `BodyBytes`))) AS `series_array` FROM (SELECT * FROM `otel_logs` WHERE (`ServiceName` = ?)) GROUP BY `ServiceName`)))
