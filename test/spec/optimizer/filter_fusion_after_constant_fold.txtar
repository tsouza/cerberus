-- unoptimized --
SELECT * FROM (SELECT * FROM `otel_metrics_gauge` PREWHERE (`MetricName` = ?)) WHERE (? AND (`job` = ?))
-- optimized --
SELECT * FROM `otel_metrics_gauge` PREWHERE (`MetricName` = ?) WHERE (`job` = ?)
-- chplan_optimized --
Filter predicate=((MetricName = "up") AND (job = "api"))
  Scan(otel_metrics_gauge)
-- chplan_unoptimized --
Filter predicate=(true AND (job = "api"))
  Filter predicate=(MetricName = "up")
    Scan(otel_metrics_gauge)
