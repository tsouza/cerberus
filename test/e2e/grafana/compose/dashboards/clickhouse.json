  "description": "ClickHouse server observability. Sourced from the sqlquery/clickhouse OTel receiver, which polls system.metrics, system.events, system.asynchronous_metrics, and system.parts every 15s and ships the rows through the same OTLP -> clickhouseexporter path as cerberus self-telemetry. Names follow the clickhouse_{metric,event,async_metric} prefix scheme with `name` carrying the original CH name.",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "cerberus-prometheus"},
      "description": "Currently executing queries on the ClickHouse server (system.metrics 'Query'). A sustained non-zero value indicates concurrent load.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 5}, {"color": "red", "value": 20}]},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "cerberus-prometheus"},
          "editorMode": "code",
          "expr": "max(clickhouse_metric{name=\"Query\"})",
          "legendFormat": "queries in flight",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "In-flight queries",
      "type": "stat"
    },
