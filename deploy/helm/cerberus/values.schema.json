{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "cerberus Helm chart values",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "commonLabels": { "type": "object" },
    "mode": { "type": "string", "enum": ["monolith", "split"] },
    "replicaCount": { "type": "integer", "minimum": 0 },
    "split": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "prometheus": { "$ref": "#/definitions/splitHead" },
        "loki": { "$ref": "#/definitions/splitHead" },
        "tempo": { "$ref": "#/definitions/splitHead" }
      }
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] },
        "digest": { "type": "string" }
      },
      "required": ["repository"]
    },
    "imagePullSecrets": { "type": "array" },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "annotations": { "type": "object" },
        "automountServiceAccountToken": { "type": "boolean" }
      }
    },
    "automountServiceAccountToken": { "type": "boolean" },
    "clickhouse": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "addr": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "database": { "type": "string" },
        "username": { "type": "string" },
        "protocol": { "type": "string", "enum": ["native", "http"] },
        "dialTimeout": { "type": "string" },
        "pool": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "maxOpenConns": { "type": ["integer", "null"], "minimum": 0 },
            "maxIdleConns": { "type": ["integer", "null"], "minimum": 0 },
            "connMaxLifetime": { "type": "string" }
          }
        },
        "password": { "type": "string" },
        "existingSecret": { "type": "string" },
        "passwordKey": { "type": "string" },
        "tls": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "insecureSkipVerify": { "type": "boolean" },
            "serverName": { "type": "string" },
            "existingSecret": { "type": "string" },
            "caFileKey": { "type": "string" },
            "certFileKey": { "type": "string" },
            "keyFileKey": { "type": "string" }
          }
        },
        "bundled": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "image": { "type": "string" },
            "replicas": { "type": "integer", "minimum": 1 },
            "storagePolicyName": { "type": "string" },
            "resources": { "type": "object" },
            "persistence": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "size": { "type": "string" },
                "storageClass": { "type": "string" }
              }
            },
            "cache": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "size": { "type": "string" }
              }
            },
            "serviceAccount": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "create": { "type": "boolean" },
                "annotations": { "type": "object" }
              }
            },
            "keeper": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": ["boolean", "null"] },
                "replicas": { "type": "integer", "minimum": 1 },
                "persistence": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "size": { "type": "string" },
                    "storageClass": { "type": "string" }
                  }
                }
              }
            },
            "objectStorage": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "backend": { "type": "string", "enum": ["s3", "gcs", "azure"] },
                "bucket": { "type": "string" },
                "path": { "type": "string" },
                "s3": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "endpoint": { "type": "string" },
                    "region": { "type": "string" },
                    "forcePathStyle": { "type": "boolean" },
                    "useEnvironmentCredentials": { "type": "boolean" },
                    "credentialsSecret": { "type": "string" },
                    "accessKeyId": { "type": "string" },
                    "secretAccessKey": { "type": "string" }
                  }
                },
                "gcs": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "credentialsSecret": { "type": "string" },
                    "accessKeyId": { "type": "string" },
                    "secretAccessKey": { "type": "string" }
                  }
                },
                "azure": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "storageAccountUrl": { "type": "string" },
                    "container": { "type": "string" },
                    "useManagedIdentity": { "type": "boolean" },
                    "credentialsSecret": { "type": "string" },
                    "accountName": { "type": "string" },
                    "accountKey": { "type": "string" }
                  }
                }
              }
            },
            "podDisruptionBudget": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "minAvailable": { "type": ["integer", "string"] }
              }
            },
            "podAntiAffinity": { "type": "boolean" },
            "configOverrides": { "type": "string" },
            "settings": {
              "type": "object",
              "additionalProperties": { "type": ["string", "number", "boolean"] }
            }
          }
        }
      },
      "required": ["addr"]
    },
    "autoCreate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema": { "type": ["boolean", "null"] },
        "database": { "type": ["boolean", "null"] }
      }
    },
    "admit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "prom": { "type": ["boolean", "integer"], "minimum": 0 },
        "loki": { "type": ["boolean", "integer"], "minimum": 0 },
        "tempo": { "type": ["boolean", "integer"], "minimum": 0 },
        "disabled": { "type": "boolean" }
      }
    },
    "otlp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "endpoint": { "type": "string" },
        "insecure": { "type": "boolean" },
        "headers": { "type": "string" },
        "exportInterval": { "type": "string" },
        "timeout": { "type": "string" }
      }
    },
    "schema": {
      "type": "object",
      "properties": {
        "ttl": { "type": "string" },
        "replicated": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "zookeeperPath": { "type": "string" }
          }
        },
        "storagePolicy": { "type": "string" },
        "settings": {
          "type": "object",
          "additionalProperties": { "type": ["string", "number", "boolean"] }
        }
      },
      "additionalProperties": { "type": ["string", "number", "boolean"] }
    },
    "requirementsCheck": { "type": "boolean" },
    "chOptimizations": { "type": "string" },
    "query": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxSamples": { "type": ["integer", "null"], "minimum": 0 },
        "timeout": { "type": "string" },
        "chMaxMemory": { "type": ["integer", "string", "null"], "minimum": 0 }
      }
    },
    "debug": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pprof": { "type": "boolean" }
      }
    },
    "prom": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "resourceLabels": { "type": "array", "items": { "type": "string" } }
      }
    },
    "http": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "addr": { "type": "string" } }
    },
    "logLevel": { "type": "string", "enum": ["debug", "info", "warn", "error"] },
    "logFormat": { "type": "string", "enum": ["json", "text"] },
    "config": { "type": "object", "additionalProperties": { "type": ["string", "number", "boolean"] } },
    "extraEnv": { "type": "array" },
    "extraEnvFrom": { "type": "array" },
    "extraArgs": { "type": "array" },
    "command": { "type": "array" },
    "args": { "type": "array" },
    "extraVolumes": { "type": "array" },
    "extraVolumeMounts": { "type": "array" },
    "extraContainers": { "type": "array" },
    "initContainers": { "type": "array" },
    "extraManifests": { "type": "array" },
    "lifecycle": { "type": "object" },
    "deploymentAnnotations": { "type": "object" },
    "podAnnotations": { "type": "object" },
    "podLabels": { "type": "object" },
    "podSecurityContext": { "type": "object" },
    "securityContext": { "type": "object" },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer", "ExternalName"] },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "targetPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "appProtocol": { "type": "string" },
        "annotations": { "type": "object" },
        "nodePort": { "type": ["integer", "null"] },
        "loadBalancerClass": { "type": "string" }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": { "type": "array" },
        "tls": { "type": "array" }
      }
    },
    "resources": { "type": "object" },
    "autoscaling": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilizationPercentage": { "type": ["integer", "null"] },
        "targetMemoryUtilizationPercentage": { "type": ["integer", "null"] },
        "extraMetrics": { "type": "array" },
        "behavior": { "type": "object" }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "type": ["integer", "string", "null"] },
        "maxUnavailable": { "type": ["integer", "string", "null"] }
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "ingress": { "type": "array" },
        "egress": { "type": "array" }
      }
    },
    "updateStrategy": { "type": "object" },
    "livenessProbe": { "type": "object" },
    "readinessProbe": { "type": "object" },
    "startupProbe": { "type": "object" },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" },
    "affinityPresets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "colocateWithClickHouse": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "mode": { "type": "string", "enum": ["preferred", "required"] },
            "podSelector": { "type": "object" },
            "topologyKey": { "type": "string" }
          }
        }
      }
    },
    "topologySpreadConstraints": { "type": "array" },
    "priorityClassName": { "type": "string" },
    "terminationGracePeriodSeconds": { "type": "integer", "minimum": 0 },
    "hostNetwork": { "type": "boolean" },
    "dnsPolicy": { "type": "string" },
    "dnsConfig": { "type": "object" }
  },
  "definitions": {
    "splitHead": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "replicaCount": { "type": ["integer", "null"], "minimum": 0 },
        "resources": { "type": ["object", "null"] },
        "maxSamples": { "type": ["integer", "null"], "minimum": 0 }
      }
    }
  }
}
