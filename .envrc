#!/usr/bin/env bash
# Cerberus dev environment — loaded by direnv.

# Local toolchain on PATH.
PATH_add bin
PATH_add "$HOME/.local/go/bin"
PATH_add "$HOME/go/bin"

# Go: allow auto-fetching newer toolchains pinned in go.mod.
export GOTOOLCHAIN=auto
export GOFLAGS="-trimpath"

# CGO left at the platform default (Linux usually enables it). The race
# detector needs it; goreleaser pins CGO_ENABLED=0 for reproducible release
# binaries on its own.

# Marker that we're in a cerberus dev shell.
export CERBERUS_DEV=1
